{
  "name": "squaark",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "css:build": "tailwindcss -i themes/linen/assets/style.src.css -o themes/linen/assets/style.css --minify",
    "css:watch": "tailwindcss -i themes/linen/assets/style.src.css -o themes/linen/assets/style.css --watch"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/csrf-protection": "^6.4.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/session": "^10.9.0",
    "@fastify/static": "^7.0.4",
    "adm-zip": "^0.5.17",
    "argon2": "^0.44.0",
    "better-sqlite3": "^9.6.0",
    "fast-xml-parser": "^5.9.3",
    "fastify": "^4.28.0",
    "handlebars": "^4.7.8",
    "lru-cache": "^10.4.3",
    "nodemailer": "^9.0.3",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/sharp": "^0.31.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
