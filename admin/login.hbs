<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign in — Squaark</title>
  <link rel="stylesheet" href="/public/admin.css">
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-card__header">
        <h1 class="auth-card__title">Squaark</h1>
        <p class="auth-card__sub">Admin</p>
      </div>
      <div class="auth-card__body">
        {{#if error}}
        <div class="alert alert-error">{{error}}</div>
        {{/if}}
        {{#if setup}}
        <div class="alert alert-success">Account created. Sign in below.</div>
        {{/if}}
        <form method="POST" action="/admin/login" class="auth-form">
          <div>
            <label class="form-label">Email</label>
            <input type="email" name="email" required autofocus class="form-input">
          </div>
          <div>
            <label class="form-label">Password</label>
            <input type="password" name="password" required class="form-input">
          </div>
          <button type="submit" class="btn btn-primary btn-block">Sign in</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
