<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <a href="/admin/collections" class="text-gray-400 hover:text-gray-600 text-sm">← Collections</a>
    <h1 class="text-2xl font-bold">{{#if collection}}{{collection.title}}{{else}}New collection{{/if}}</h1>
  </div>
  {{#if collection}}
  <form method="POST" action="/admin/collections/{{collection.id}}/delete" onsubmit="return confirm('Delete this collection?')">
    <button type="submit" class="text-red-500 text-sm hover:underline">Delete</button>
  </form>
  {{/if}}
</div>

{{#if error}}<div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">{{error}}</div>{{/if}}
{{#if saved}}<div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Saved.</div>{{/if}}

<div class="grid grid-cols-3 gap-6">
  <div class="col-span-2 space-y-5">
    <form method="POST" action="/admin/collections/{{#if collection}}{{collection.id}}{{else}}new{{/if}}">
      <div class="bg-white rounded-xl border border-gray-200 p-5 space-y-4">
        <h2 class="font-semibold">Details</h2>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
          <input type="text" name="title" value="{{collection.title}}" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Slug <span class="text-red-500">*</span></label>
          <div class="flex items-center gap-2">
            <span class="text-gray-400 text-sm">/collections/</span>
            <input type="text" name="slug" value="{{collection.slug}}" required
              class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea name="description" rows="3"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">{{collection.description}}</textarea>
        </div>
      </div>
      <div class="mt-5 flex items-center gap-4">
        <button type="submit" class="bg-gray-900 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-700">
          {{#if collection}}Save changes{{else}}Create collection{{/if}}
        </button>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" name="published" value="1" {{#if (eq collection.published 1)}}checked{{/if}} class="rounded">
          Published
        </label>
      </div>
    </form>

    {{#if collection}}
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold mb-4">Products in this collection</h2>
      {{#if products.length}}
      <ul class="divide-y divide-gray-100 mb-4">
        {{#each products}}
        <li class="flex items-center justify-between py-2">
          <span class="text-sm">{{this.title}}</span>
          <form method="POST" action="/admin/collections/{{../collection.id}}/products/{{this.id}}/remove">
            <button type="submit" class="text-xs text-red-500 hover:underline">Remove</button>
          </form>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="text-sm text-gray-400 mb-4">No products yet.</p>
      {{/if}}
      {{#if allProducts.length}}
      <form method="POST" action="/admin/collections/{{collection.id}}/products/add" class="flex gap-2">
        <select name="product_id" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          <option value="">— Select a product —</option>
          {{#each allProducts}}
          <option value="{{this.id}}">{{this.title}}</option>
          {{/each}}
        </select>
        <button type="submit" class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-700">Add</button>
      </form>
      {{/if}}
    </div>
    {{/if}}
  </div>

  <div class="space-y-4">
    {{#if collection}}
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-xs text-gray-400 space-y-1">
      <p>Created {{date_short collection.created_at}}</p>
    </div>
    {{/if}}
  </div>
</div>
