<div class="page-header">
  <div class="page-header__left">
    <a href="/admin/collections" class="page-back">← Collections</a>
    <h1 class="page-title">{{#if collection}}{{collection.title}}{{else}}New collection{{/if}}</h1>
  </div>
  {{#if collection}}
  <form method="POST" action="/admin/collections/{{collection.id}}/delete" onsubmit="return confirm('Delete this collection?')">
    <button type="submit" class="btn-link btn-link--danger btn-link--sm">Delete</button>
  </form>
  {{/if}}
</div>

{{#if error}}<div class="alert alert-error">{{error}}</div>{{/if}}
{{#if saved}}<div class="alert alert-success">Saved.</div>{{/if}}

<div class="grid-form">
  <div class="stack">
    <form method="POST" action="/admin/collections/{{#if collection}}{{collection.id}}{{else}}new{{/if}}">
      <div class="card--no-overflow card-body stack-sm">
        <h2 class="font-semibold">Details</h2>
        <div>
          <label class="form-label">Title <span class="form-required">*</span></label>
          <input type="text" name="title" value="{{collection.title}}" required class="form-input">
        </div>
        <div>
          <label class="form-label">Slug <span class="form-required">*</span></label>
          <div class="form-prefix">
            <span class="form-prefix-text">/collections/</span>
            <input type="text" name="slug" value="{{collection.slug}}" required class="form-input flex-1">
          </div>
        </div>
        <div>
          <label class="form-label">Description</label>
          <textarea name="description" rows="3" class="form-textarea">{{collection.description}}</textarea>
        </div>
      </div>
      <div class="mt-4 row">
        <button type="submit" class="btn btn-primary">
          {{#if collection}}Save changes{{else}}Create collection{{/if}}
        </button>
        <label class="form-check">
          <input type="checkbox" name="published" value="1" {{#if (eq collection.published 1)}}checked{{/if}}>
          Published
        </label>
      </div>
    </form>

    {{#if collection}}
    <div class="card--no-overflow card-body">
      <h2 class="font-semibold mb-4">Products in this collection</h2>
      {{#if products.length}}
      <ul style="border-top:1px solid #f3f4f6;" class="mb-4">
        {{#each products}}
        <li style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid #f3f4f6;">
          <span class="text-sm">{{this.title}}</span>
          <form method="POST" action="/admin/collections/{{../collection.id}}/products/{{this.id}}/remove">
            <button type="submit" class="btn-link btn-link--danger btn-link--xs">Remove</button>
          </form>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="text-sm text-muted mb-4">No products yet.</p>
      {{/if}}
      {{#if allProducts.length}}
      <form method="POST" action="/admin/collections/{{collection.id}}/products/add" class="row">
        <select name="product_id" class="form-select flex-1">
          <option value="">— Select a product —</option>
          {{#each allProducts}}
          <option value="{{this.id}}">{{this.title}}</option>
          {{/each}}
        </select>
        <button type="submit" class="btn btn-primary btn-sm">Add</button>
      </form>
      {{/if}}
    </div>
    {{/if}}
  </div>

  <div class="stack-sm">
    {{#if collection}}
    <div class="card--no-overflow card-body text-xs text-muted">
      <p>Created {{date_short collection.created_at}}</p>
    </div>
    {{/if}}
  </div>
</div>
