<div class="page-header">
  <h1 class="page-title">Collections</h1>
  <a href="/admin/collections/new" class="btn btn-primary btn-sm">Add collection</a>
</div>

<div class="card">
  {{#if collections.length}}
  <table class="data-table">
    <thead>
      <tr>
        <th>Collection</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each collections}}
      <tr>
        <td>
          <a href="/admin/collections/{{this.id}}" class="cell-title">{{this.title}}</a>
          <p class="cell-hint">/collections/{{this.slug}}</p>
        </td>
        <td>
          {{#if (eq this.published 1)}}
          <span class="badge badge-green">Active</span>
          {{else}}
          <span class="badge badge-gray">Draft</span>
          {{/if}}
        </td>
        <td class="right"><a href="/admin/collections/{{this.id}}" class="cell-action">Edit →</a></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state">
    <p>No collections yet.</p>
    <a href="/admin/collections/new">Create your first collection</a>
  </div>
  {{/if}}
</div>
