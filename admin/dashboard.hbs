<div class="page-header">
  <h1 class="page-title">Dashboard</h1>
  <span class="text-muted text-sm">Welcome back, {{admin.name}}</span>
</div>

{{#if isEmpty}}
<div class="onboard-banner">
  <div class="onboard-banner__icon">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z" />
    </svg>
  </div>
  <div class="flex-1">
    <p class="onboard-banner__title">Your store is empty</p>
    <p class="onboard-banner__body">Got an existing WordPress / WooCommerce store? Import your products, orders and pages in a few clicks.</p>
    <div class="onboard-banner__actions">
      <a href="/admin/import" class="onboard-banner__cta">Import from WordPress</a>
      <a href="/admin/products/new" class="onboard-banner__link">Add a product manually</a>
    </div>
  </div>
</div>
{{/if}}

<div class="grid-3 mb-8">
  <div class="stat-card">
    <p class="stat-card__label">Orders</p>
    <p class="stat-card__value">{{stats.orderCount}}</p>
  </div>
  <div class="stat-card">
    <p class="stat-card__label">Products</p>
    <p class="stat-card__value">{{stats.productCount}}</p>
  </div>
  <div class="stat-card">
    <p class="stat-card__label">Revenue</p>
    <p class="stat-card__value">—</p>
  </div>
</div>

<div class="quick-actions mb-8">
  <a href="/admin/products/new" class="quick-action">
    <p class="quick-action__title">Add a product</p>
    <p class="quick-action__sub">Create a new product listing</p>
  </a>
  <a href="/admin/orders" class="quick-action">
    <p class="quick-action__title">View orders</p>
    <p class="quick-action__sub">Manage and fulfil orders</p>
  </a>
</div>

<div class="traffic-section">
  <h2>Traffic</h2>

  <div class="grid-3 mb-4">
    <div class="stat-card">
      <p class="stat-card__label">Today</p>
      <p class="stat-card__value">{{analytics.visitsToday}}</p>
      <p class="stat-card__sub">page views</p>
    </div>
    <div class="stat-card">
      <p class="stat-card__label">Last 7 days</p>
      <p class="stat-card__value">{{analytics.visits7d}}</p>
      <p class="stat-card__sub">page views</p>
    </div>
    <div class="stat-card">
      <p class="stat-card__label">Unique visitors</p>
      <p class="stat-card__value">{{analytics.uniqueVisitors7d}}</p>
      <p class="stat-card__sub">last 7 days</p>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <p class="text-sm text-muted mb-3">Page views — last 7 days</p>
      {{{sparkline_bars analytics.daily7d}}}
    </div>
  </div>

  <div class="grid-2">
    <div class="card">
      <div class="card-body">
        <p class="font-medium text-sm mb-3">Top pages <span class="text-muted text-xs font-normal">(30 days)</span></p>
        {{#if analytics.topPages.length}}
        <ul class="traffic-list">
          {{#each analytics.topPages}}
          <li>
            <span class="traffic-list__path">{{this.path}}</span>
            <span class="traffic-list__count">{{this.views}}</span>
          </li>
          {{/each}}
        </ul>
        {{else}}
        <p class="text-sm text-muted">No data yet.</p>
        {{/if}}
      </div>
    </div>
    <div class="card">
      <div class="card-body">
        <p class="font-medium text-sm mb-3">Top referrers <span class="text-muted text-xs font-normal">(30 days)</span></p>
        {{#if analytics.topReferrers.length}}
        <ul class="traffic-list">
          {{#each analytics.topReferrers}}
          <li>
            <span class="traffic-list__path">{{this.referrer}}</span>
            <span class="traffic-list__count">{{this.views}}</span>
          </li>
          {{/each}}
        </ul>
        {{else}}
        <p class="text-sm text-muted">No referral traffic yet.</p>
        {{/if}}
      </div>
    </div>
  </div>
</div>
