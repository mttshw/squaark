<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold">Dashboard</h1>
  <span class="text-sm text-gray-500">Welcome back, {{admin.name}}</span>
</div>

{{#if isEmpty}}
<div class="bg-blue-50 border border-blue-200 rounded-xl p-5 mb-8 flex items-start gap-4">
  <div class="text-blue-500 mt-0.5 shrink-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z" />
    </svg>
  </div>
  <div class="flex-1">
    <p class="font-semibold text-blue-900 mb-1">Your store is empty</p>
    <p class="text-sm text-blue-700 mb-3">Got an existing WordPress / WooCommerce store? Import your products, orders and pages in a few clicks.</p>
    <div class="flex gap-3">
      <a href="/admin/import" class="inline-block bg-blue-600 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">Import from WordPress</a>
      <a href="/admin/products/new" class="inline-block text-blue-700 text-sm font-medium px-4 py-2 rounded-lg hover:bg-blue-100 transition-colors">Add a product manually</a>
    </div>
  </div>
</div>
{{/if}}

<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <p class="text-sm text-gray-500 mb-1">Orders</p>
    <p class="text-3xl font-bold">{{stats.orderCount}}</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <p class="text-sm text-gray-500 mb-1">Products</p>
    <p class="text-3xl font-bold">{{stats.productCount}}</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <p class="text-sm text-gray-500 mb-1">Revenue</p>
    <p class="text-3xl font-bold">—</p>
  </div>
</div>

<div class="grid grid-cols-2 gap-4">
  <a href="/admin/products/new" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-gray-400 transition-colors block">
    <p class="font-semibold mb-1">Add a product</p>
    <p class="text-sm text-gray-500">Create a new product listing</p>
  </a>
  <a href="/admin/orders" class="bg-white rounded-xl border border-gray-200 p-5 hover:border-gray-400 transition-colors block">
    <p class="font-semibold mb-1">View orders</p>
    <p class="text-sm text-gray-500">Manage and fulfil orders</p>
  </a>
</div>

<!-- Traffic analytics -->
<div class="mt-8">
  <h2 class="text-base font-semibold mb-3">Traffic</h2>

  <!-- Visit stats -->
  <div class="grid grid-cols-3 gap-4 mb-4">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-sm text-gray-500 mb-1">Today</p>
      <p class="text-3xl font-bold">{{analytics.visitsToday}}</p>
      <p class="text-xs text-gray-400 mt-1">page views</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-sm text-gray-500 mb-1">Last 7 days</p>
      <p class="text-3xl font-bold">{{analytics.visits7d}}</p>
      <p class="text-xs text-gray-400 mt-1">page views</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-sm text-gray-500 mb-1">Unique visitors</p>
      <p class="text-3xl font-bold">{{analytics.uniqueVisitors7d}}</p>
      <p class="text-xs text-gray-400 mt-1">last 7 days</p>
    </div>
  </div>

  <!-- 7-day bar chart -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-4">
    <p class="text-sm text-gray-500 mb-4">Page views — last 7 days</p>
    {{{sparkline_bars analytics.daily7d}}}
  </div>

  <!-- Top pages + referrers -->
  <div class="grid grid-cols-2 gap-4">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-sm font-medium text-gray-700 mb-3">Top pages <span class="text-xs text-gray-400 font-normal">(30 days)</span></p>
      {{#if analytics.topPages.length}}
      <ul class="space-y-2">
        {{#each analytics.topPages}}
        <li class="flex items-center justify-between text-sm">
          <span class="text-gray-600 truncate mr-2">{{this.path}}</span>
          <span class="text-gray-900 font-medium flex-shrink-0">{{this.views}}</span>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="text-sm text-gray-400">No data yet.</p>
      {{/if}}
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-sm font-medium text-gray-700 mb-3">Top referrers <span class="text-xs text-gray-400 font-normal">(30 days)</span></p>
      {{#if analytics.topReferrers.length}}
      <ul class="space-y-2">
        {{#each analytics.topReferrers}}
        <li class="flex items-center justify-between text-sm">
          <span class="text-gray-600 truncate mr-2">{{this.referrer}}</span>
          <span class="text-gray-900 font-medium flex-shrink-0">{{this.views}}</span>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="text-sm text-gray-400">No referral traffic yet.</p>
      {{/if}}
    </div>
  </div>
</div>
