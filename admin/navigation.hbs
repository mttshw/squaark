<div class="page-header">
  <h1 class="page-title">Navigation</h1>
</div>

{{#if saved}}<div class="alert alert-success">Saved.</div>{{/if}}

<form method="POST" action="/admin/navigation">

  <div class="grid-2 mb-6">

    <!-- Header nav -->
    <div class="card--no-overflow card-body"
         x-data="navEditor()"
         x-init="init($el.dataset.items)"
         data-items='{{mainNavSafe}}'>
      <h2 class="font-semibold mb-4">Header navigation</h2>
      <div class="stack-xs mb-3">
        <template x-for="(item, i) in items" :key="i">
          <div class="row">
            <input x-model="item.label" placeholder="Label" type="text" class="form-input" style="width:7rem;">
            <input x-model="item.url" placeholder="URL e.g. /about" type="text" class="form-input flex-1">
            <button type="button" @click="moveUp(i)" :disabled="i === 0"
              style="padding:0.25rem;color:#9ca3af;" title="Move up">↑</button>
            <button type="button" @click="moveDown(i)" :disabled="i === items.length - 1"
              style="padding:0.25rem;color:#9ca3af;" title="Move down">↓</button>
            <button type="button" @click="items.splice(i, 1)"
              style="padding:0.25rem;color:#9ca3af;" title="Remove">✕</button>
          </div>
        </template>
      </div>
      <button type="button" @click="items.push({label:'',url:''})" class="btn-link text-sm">+ Add link</button>
      <input type="hidden" name="nav_main" :value="JSON.stringify(items)">
    </div>

    <!-- Footer nav -->
    <div class="card--no-overflow card-body"
         x-data="navEditor()"
         x-init="init($el.dataset.items)"
         data-items='{{footerNavSafe}}'>
      <h2 class="font-semibold mb-4">Footer navigation</h2>
      <div class="stack-xs mb-3">
        <template x-for="(item, i) in items" :key="i">
          <div class="row">
            <input x-model="item.label" placeholder="Label" type="text" class="form-input" style="width:7rem;">
            <input x-model="item.url" placeholder="URL e.g. /about" type="text" class="form-input flex-1">
            <button type="button" @click="moveUp(i)" :disabled="i === 0"
              style="padding:0.25rem;color:#9ca3af;" title="Move up">↑</button>
            <button type="button" @click="moveDown(i)" :disabled="i === items.length - 1"
              style="padding:0.25rem;color:#9ca3af;" title="Move down">↓</button>
            <button type="button" @click="items.splice(i, 1)"
              style="padding:0.25rem;color:#9ca3af;" title="Remove">✕</button>
          </div>
        </template>
      </div>
      <button type="button" @click="items.push({label:'',url:''})" class="btn-link text-sm">+ Add link</button>
      <input type="hidden" name="nav_footer" :value="JSON.stringify(items)">
    </div>

  </div>

  <button type="submit" class="btn btn-primary">Save navigation</button>

</form>

<script>
function navEditor() {
  return {
    items: [],
    init(json) {
      try { this.items = JSON.parse(json || '[]'); } catch { this.items = []; }
    },
    moveUp(i) {
      if (i === 0) return;
      [this.items[i - 1], this.items[i]] = [this.items[i], this.items[i - 1]];
      this.items = [...this.items];
    },
    moveDown(i) {
      if (i === this.items.length - 1) return;
      [this.items[i], this.items[i + 1]] = [this.items[i + 1], this.items[i]];
      this.items = [...this.items];
    }
  };
}
</script>
