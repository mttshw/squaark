<div class="page-header">
  <h1 class="page-title">Orders</h1>
  <span class="text-muted text-sm">{{total}} total</span>
</div>

<div class="card">
  {{#if orders.length}}
  <table class="data-table">
    <thead>
      <tr>
        <th>Order</th>
        <th>Customer</th>
        <th>Status</th>
        <th>Total</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      {{#each orders}}
      <tr>
        <td class="cell-title">
          <a href="/admin/orders/{{this.id}}">#{{this.order_number}}</a>
        </td>
        <td>{{this.email}}</td>
        <td>{{{status_badge this.status}}}</td>
        <td>£{{money_pence this.total}}</td>
        <td class="text-muted text-xs">{{date_short this.created_at}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state">
    <p>No orders yet. Orders will appear here once customers complete checkout.</p>
  </div>
  {{/if}}
</div>

{{#if (gt totalPages 1)}}
<div class="admin-pagination mt-4">
  {{#if (gt page 1)}}
  <a href="?page={{subtract page 1}}">← Previous</a>
  {{else}}<span></span>{{/if}}
  <span class="admin-pagination__info">Page {{page}} of {{totalPages}}</span>
  {{#if (lt page totalPages)}}
  <a href="?page={{add page 1}}">Next →</a>
  {{else}}<span></span>{{/if}}
</div>
{{/if}}
