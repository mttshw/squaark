<div class="page-header__left mb-6">
  <a href="/admin/orders" class="page-back">← Orders</a>
  <h1 class="page-title">Order #{{order.order_number}}</h1>
  {{{status_badge order.status}}}
</div>

<div class="grid-form">
  <div class="stack">
    <div class="card">
      <div class="card-header">Items</div>
      <table class="data-table">
        <tbody>
          {{#each items}}
          <tr>
            <td>
              <p class="cell-title">{{this.product_title}}</p>
              <p class="cell-hint">{{this.variant_title}}{{#if this.sku}} · SKU: {{this.sku}}{{/if}}</p>
            </td>
            <td class="right text-muted">× {{this.quantity}}</td>
            <td class="right cell-title">£{{money_pence this.line_total}}</td>
          </tr>
          {{/each}}
        </tbody>
        <tfoot>
          <tr>
            <td colspan="2">Subtotal</td>
            <td class="right">£{{money_pence order.subtotal}}</td>
          </tr>
          {{#if order.discount_amount}}
          <tr>
            <td colspan="2">Discount{{#if order.discount_code}} ({{order.discount_code}}){{/if}}</td>
            <td class="right text-success">−£{{money_pence order.discount_amount}}</td>
          </tr>
          {{/if}}
          <tr>
            <td colspan="2" class="font-semibold">Total</td>
            <td class="right font-semibold">£{{money_pence order.total}}</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="stack-sm">
    <div class="card--no-overflow card-body">
      <h2 class="font-semibold text-sm mb-3">Customer</h2>
      <p class="text-sm">{{order.email}}</p>
    </div>
    <div class="card--no-overflow card-body-sm text-xs text-muted stack-xs">
      <p>Placed {{date_short order.created_at}}</p>
      <p>Fulfillment: {{order.fulfillment}}</p>
    </div>
  </div>
</div>
