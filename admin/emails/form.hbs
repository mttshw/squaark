<div class="flex items-center gap-3 mb-6">
  <a href="/admin/emails" class="text-gray-400 hover:text-gray-600 text-sm">← Emails</a>
  <h1 class="text-2xl font-bold">{{template.name}}</h1>
</div>

{{#if saved}}
<div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Template saved.</div>
{{/if}}

<div class="grid grid-cols-2 gap-6">
  <div>
    <form method="POST" action="/admin/emails/{{template.key}}" class="bg-white rounded-xl border border-gray-200 p-5 space-y-4">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="enabled" value="on" {{#if (eq template.enabled 1)}}checked{{/if}} class="rounded">
        <span class="text-sm text-gray-600">Enabled</span>
      </label>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
        <input type="text" id="subject" name="subject" value="{{template.subject}}"
          hx-post="/admin/emails/{{template.key}}/preview" hx-trigger="keyup changed delay:400ms"
          hx-target="#email-preview" hx-swap="innerHTML" hx-include="#subject,#body"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-gray-900">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Body (HTML, Handlebars)</label>
        <textarea id="body" name="body" rows="16"
          hx-post="/admin/emails/{{template.key}}/preview" hx-trigger="keyup changed delay:400ms"
          hx-target="#email-preview" hx-swap="innerHTML" hx-include="#subject,#body"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-gray-900">{{template.body}}</textarea>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="bg-gray-900 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-700">
          Save
        </button>
        <button type="button" hx-post="/admin/emails/{{template.key}}/test" hx-target="#test-status" hx-swap="innerHTML"
          class="border border-gray-200 text-gray-600 px-4 py-2 rounded-lg text-sm font-medium hover:border-gray-400">
          Send test to me
        </button>
        <span id="test-status"></span>
      </div>
    </form>
  </div>

  <div>
    <p class="text-xs text-gray-400 mb-2">Preview (sample data)</p>
    <div id="email-preview" class="bg-white rounded-xl border border-gray-200 p-4 overflow-auto" style="max-height:600px;">
      {{{previewHtml}}}
    </div>
  </div>
</div>
