<div class="page-header">
  <div class="page-header__left">
    <a href="/admin/emails" class="page-back">← Emails</a>
    <h1 class="page-title">{{template.name}}</h1>
  </div>
</div>

{{#if saved}}<div class="alert alert-success">Template saved.</div>{{/if}}

<div class="grid-2">
  <div>
    <form method="POST" action="/admin/emails/{{template.key}}" class="card--no-overflow card-body stack-sm">
      <label class="form-check">
        <input type="checkbox" name="enabled" value="on" {{#if (eq template.enabled 1)}}checked{{/if}}>
        <span class="text-sm">Enabled</span>
      </label>

      <div>
        <label class="form-label">Subject</label>
        <input type="text" id="subject" name="subject" value="{{template.subject}}"
          hx-post="/admin/emails/{{template.key}}/preview" hx-trigger="keyup changed delay:400ms"
          hx-target="#email-preview" hx-swap="innerHTML" hx-include="#subject,#body"
          class="form-input font-mono">
      </div>

      <div>
        <label class="form-label">Body (HTML, Handlebars)</label>
        <textarea id="body" name="body" rows="16"
          hx-post="/admin/emails/{{template.key}}/preview" hx-trigger="keyup changed delay:400ms"
          hx-target="#email-preview" hx-swap="innerHTML" hx-include="#subject,#body"
          class="form-textarea font-mono">{{template.body}}</textarea>
      </div>

      <div class="row">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" hx-post="/admin/emails/{{template.key}}/test" hx-target="#test-status" hx-swap="innerHTML"
          class="btn btn-secondary">
          Send test to me
        </button>
        <span id="test-status"></span>
      </div>
    </form>
  </div>

  <div>
    <p class="text-xs text-muted mb-2">Preview (sample data)</p>
    <div id="email-preview" class="card--no-overflow card-body" style="overflow:auto;max-height:600px;">
      {{{previewHtml}}}
    </div>
  </div>
</div>
