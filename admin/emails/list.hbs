<div class="page-header">
  <h1 class="page-title">Emails</h1>
</div>

<div class="card mb-6">
  <table class="data-table">
    <thead>
      <tr>
        <th>Email</th>
        <th>Subject</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each templates}}
      <tr>
        <td><a href="/admin/emails/{{this.key}}" class="cell-title">{{this.name}}</a></td>
        <td class="text-muted">{{this.subject}}</td>
        <td>
          {{#if (eq this.enabled 1)}}
          <span class="badge badge-green">Enabled</span>
          {{else}}
          <span class="badge badge-gray">Disabled</span>
          {{/if}}
        </td>
        <td class="right"><a href="/admin/emails/{{this.key}}" class="cell-action">Edit →</a></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<div class="card--no-overflow card-body">
  <h2 class="font-semibold mb-3">Recent sends</h2>
  {{#if log.length}}
  <table class="data-table">
    <thead>
      <tr>
        <th>To</th>
        <th>Subject</th>
        <th>Provider</th>
        <th>Status</th>
        <th>When</th>
      </tr>
    </thead>
    <tbody>
      {{#each log}}
      <tr>
        <td>{{this.to_address}}</td>
        <td class="text-muted">{{this.subject}}</td>
        <td class="text-muted">{{this.provider}}</td>
        <td>
          {{#if (eq this.status 'sent')}}
          <span class="text-xs font-medium" style="color:#16a34a;">Sent</span>
          {{else}}
          <span class="text-xs font-medium" style="color:#dc2626;" title="{{this.error}}">Failed</span>
          {{/if}}
        </td>
        <td class="text-muted text-xs">{{date_short this.created_at}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p class="text-sm text-muted">No emails sent yet. Configure a provider in <a href="/admin/settings#email">Settings</a> and send a test.</p>
  {{/if}}
</div>
