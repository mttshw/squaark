<div class="page-header">
  <div>
    <h1 class="page-title">Import</h1>
    <p class="text-sm text-muted" style="margin-top:0.25rem;">Bring products, categories, images, orders and pages in from an existing WooCommerce store.</p>
  </div>
</div>

{{#if error}}
<div class="alert alert-error">
  {{#if (eq error 'no_file')}}Please choose a file to upload.{{/if}}
  {{#if (eq error 'missing_fields')}}Store URL, consumer key and consumer secret are all required.{{/if}}
</div>
{{/if}}

{{#if activeJob}}
{{> import-job job=activeJob}}
{{/if}}

<div class="grid-2">
  <!-- WordPress export file -->
  <div class="card--no-overflow card-body stack-sm">
    <div>
      <h2 class="font-semibold">WordPress export file</h2>
      <p class="text-xs text-muted mt-1">
        In your WooCommerce site: <strong>Tools → Export → All content</strong>, download the XML file, upload it here.
        No API keys needed. Imports products, variants, images, categories and pages.
      </p>
    </div>
    <form method="POST" action="/admin/import/wxr" enctype="multipart/form-data" class="stack-sm">
      <input type="file" name="file" accept=".xml" required class="form-file">
      <div>
        <button type="submit" class="btn btn-primary">Upload &amp; import</button>
      </div>
    </form>
  </div>

  <!-- WooCommerce REST API -->
  <div class="card--no-overflow card-body stack-sm">
    <div>
      <h2 class="font-semibold">WooCommerce REST API</h2>
      <p class="text-xs text-muted mt-1">
        In your WooCommerce site: <strong>Settings → Advanced → REST API → Add key</strong> (read access is enough).
        Required for orders — WooCommerce doesn't include those in a WordPress export.
      </p>
    </div>
    <form method="POST" action="/admin/import/woocommerce" class="stack-sm">
      <div>
        <label class="form-label-xs">Store URL</label>
        <input type="url" name="store_url" placeholder="https://oldstore.com" required class="form-input">
      </div>
      <div>
        <label class="form-label-xs">Consumer key</label>
        <input type="text" name="consumer_key" placeholder="ck_..." required class="form-input font-mono">
      </div>
      <div>
        <label class="form-label-xs">Consumer secret</label>
        <input type="password" name="consumer_secret" placeholder="cs_..." required class="form-input font-mono">
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;padding-top:0.25rem;">
        <label class="form-check">
          <input type="checkbox" name="import_products" value="on" checked>
          Products &amp; categories
        </label>
        <label class="form-check">
          <input type="checkbox" name="import_orders" value="on" checked>
          Past orders
        </label>
        <label class="form-check">
          <input type="checkbox" name="import_pages" value="on" checked>
          Pages
        </label>
      </div>
      <p class="text-xs text-muted">Pages require WP core REST API access — works with WC keys if the user has editor permissions.</p>
      <div>
        <button type="submit" class="btn btn-primary">Connect &amp; import</button>
      </div>
    </form>
  </div>
</div>

<p class="text-xs text-muted mt-4">
  Re-running an import updates existing records instead of duplicating them (matched by original WooCommerce ID).
  Imported orders are record-only — payment details aren't carried over.
  Pages are imported as HTML content; they'll be served from <code>/{slug}</code>.
</p>

{{#if jobs.length}}
<div class="card--no-overflow card-body mt-6">
  <h2 class="font-semibold mb-3">Recent imports</h2>
  <table class="data-table">
    <thead>
      <tr>
        <th>Source</th>
        <th>Status</th>
        <th>Result</th>
        <th>When</th>
      </tr>
    </thead>
    <tbody>
      {{#each jobs}}
      <tr>
        <td>{{this.source}}</td>
        <td>
          {{#if (eq this.status 'completed')}}<span class="text-xs font-medium" style="color:#16a34a;">Completed</span>{{/if}}
          {{#if (eq this.status 'failed')}}<span class="text-xs font-medium" style="color:#dc2626;">Failed</span>{{/if}}
          {{#if (eq this.status 'running')}}<span class="text-xs font-medium" style="color:#2563eb;">Running</span>{{/if}}
        </td>
        <td class="text-muted">{{this.stage}}</td>
        <td class="text-muted text-xs">{{date_short this.created_at}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{/if}}
