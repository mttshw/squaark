<div class="page-header">
  <h1 class="page-title">Users</h1>
</div>

{{#if saved}}<div class="alert alert-success">Saved.</div>{{/if}}
{{#if error}}
<div class="alert alert-error">
  {{#if (eq error 'email_taken')}}That email address is already in use.{{/if}}
  {{#if (eq error 'missing_fields')}}Name, email and password are all required.{{/if}}
  {{#if (eq error 'last_admin')}}There must be at least one admin — promote another user first.{{/if}}
  {{#if (eq error 'cannot_delete_self')}}You can't delete your own account.{{/if}}
  {{#if (eq error 'cannot_change_own_role')}}You can't change your own role.{{/if}}
</div>
{{/if}}

<div class="grid-form">

  <!-- User list -->
  <div>
    <div class="card">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Joined</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each users}}
          <tr>
            <td class="font-medium">
              {{this.name}}
              {{#if (eq this.id ../admin.id)}}<span class="text-xs text-muted font-normal">(you)</span>{{/if}}
            </td>
            <td class="text-muted">{{this.email}}</td>
            <td>
              {{#if (eq this.id ../admin.id)}}
              <span class="badge badge-dark">{{this.role}}</span>
              {{else}}
              <form method="POST" action="/admin/users/{{this.id}}/role" style="display:inline-flex;align-items:center;gap:0.25rem;">
                <select name="role" onchange="this.form.submit()" class="form-select" style="font-size:0.75rem;padding:0.125rem 0.375rem;">
                  <option value="admin" {{#if (eq this.role 'admin')}}selected{{/if}}>Admin</option>
                  <option value="staff" {{#if (eq this.role 'staff')}}selected{{/if}}>Staff</option>
                </select>
              </form>
              {{/if}}
            </td>
            <td class="text-muted text-xs">{{date_short this.created_at}}</td>
            <td class="right">
              {{#if (ne this.id ../admin.id)}}
              <form method="POST" action="/admin/users/{{this.id}}/delete"
                onsubmit="return confirm('Delete {{this.name}}? This cannot be undone.')">
                <button type="submit" class="btn-link btn-link--danger btn-link--xs">Delete</button>
              </form>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add user form -->
  <div class="stack-sm">
    <div class="card--no-overflow card-body stack-sm">
      <h2 class="font-semibold">Add user</h2>
      <form method="POST" action="/admin/users" class="stack-sm">
        <div>
          <label class="form-label-xs">Name</label>
          <input type="text" name="name" required class="form-input">
        </div>
        <div>
          <label class="form-label-xs">Email</label>
          <input type="email" name="email" required class="form-input">
        </div>
        <div>
          <label class="form-label-xs">Password</label>
          <input type="password" name="password" required minlength="8" class="form-input">
        </div>
        <div>
          <label class="form-label-xs">Role</label>
          <select name="role" class="form-select">
            <option value="staff">Staff — products &amp; orders only</option>
            <option value="admin">Admin — full access</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Add user</button>
      </form>
    </div>
    <p class="text-xs text-muted">
      Staff can manage products, collections and orders but cannot access settings, themes, or import.
    </p>
  </div>

</div>
