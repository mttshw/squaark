<div class="flex items-center gap-3 mb-6">
  <a href="/admin/themes" class="text-gray-400 hover:text-gray-600 text-sm">← Themes</a>
  <h1 class="text-2xl font-bold">{{theme.name}} — Customise</h1>
  {{#if (eq theme.active 1)}}
  <span class="px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Active</span>
  {{/if}}
</div>

{{#if saved}}
<div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Settings saved. Changes are live.</div>
{{/if}}

<div class="grid grid-cols-3 gap-6">
  <div class="col-span-2">
    <form method="POST" action="/admin/themes/{{theme.id}}/config">

      {{#each sections}}
      <div class="bg-white rounded-xl border border-gray-200 p-5 space-y-4 mb-5">
        <h2 class="font-semibold capitalize">{{this.name}}</h2>

        {{#each this.fields}}
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">{{this.label}}</label>

          {{#if (eq this.type 'color')}}
          <div class="flex items-center gap-3">
            <input type="color" name="{{this.flatKey}}" value="{{this.value}}" id="color-{{this.flatKey}}"
              class="h-9 w-16 rounded border border-gray-300 cursor-pointer p-0.5"
              oninput="document.getElementById('text-{{this.flatKey}}').value=this.value">
            <input type="text" id="text-{{this.flatKey}}" value="{{this.value}}"
              class="w-28 px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-gray-900"
              oninput="document.getElementById('color-{{this.flatKey}}').value=this.value">
          </div>

          {{else if (eq this.type 'select')}}
          <select name="{{this.flatKey}}"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            {{#each this.options}}
            <option value="{{this}}" {{#if (eq this ../value)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>

          {{else if (eq this.type 'boolean')}}
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="{{this.flatKey}}" value="true"
              {{#if this.value}}checked{{/if}} class="rounded">
            <span class="text-sm text-gray-600">Enabled</span>
          </label>

          {{else}}
          <input type="text" name="{{this.flatKey}}" value="{{this.value}}"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/each}}

      <div class="flex gap-3">
        <button type="submit" class="bg-gray-900 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-700">
          Save changes
        </button>
        <a href="/" target="_blank" class="border border-gray-200 text-gray-600 px-6 py-2 rounded-lg text-sm font-medium hover:border-gray-400">
          Preview store ↗
        </a>
      </div>
    </form>
  </div>

  <div class="space-y-4">
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-xs text-gray-400 space-y-1">
      <p class="font-medium text-gray-600 mb-2">Theme info</p>
      <p>Version: {{theme.version}}</p>
      <p>Author: {{theme.author}}</p>
      <p>Directory: {{theme.directory}}</p>
    </div>
  </div>
</div>
