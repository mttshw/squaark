<div style="display:flex;height:100%;overflow:hidden;">

  <!-- ── Config panel (left) ─────────────────────────────────────────────── -->
  <div style="width:400px;flex-shrink:0;overflow-y:auto;border-right:1px solid #e5e7eb;background:#fff;display:flex;flex-direction:column;">

    <!-- Header -->
    <div style="padding:1rem 1.25rem;border-bottom:1px solid #e5e7eb;position:sticky;top:0;background:#fff;z-index:10;">
      <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
        <a href="/admin/themes" style="color:#9ca3af;font-size:0.75rem;text-decoration:none;">← Themes</a>
        <span style="font-weight:600;font-size:0.9rem;">{{theme.name}}</span>
        {{#if (eq theme.active 1)}}
        <span style="background:#dcfce7;color:#166534;font-size:0.65rem;font-weight:600;padding:0.15rem 0.4rem;border-radius:0.25rem;">Active</span>
        {{/if}}
      </div>
      {{#if saved}}
      <div style="margin-top:0.5rem;padding:0.4rem 0.6rem;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:0.375rem;font-size:0.75rem;color:#166534;">
        Saved — preview updated.
      </div>
      {{/if}}
      {{#if error}}
      <div style="margin-top:0.5rem;padding:0.4rem 0.6rem;background:#fef2f2;border:1px solid #fecaca;border-radius:0.375rem;font-size:0.75rem;color:#991b1b;">
        {{error}}
      </div>
      {{/if}}
    </div>

    {{!-- Ghost form element — non-image inputs associate with it via form="config-form" --}}
    <form id="config-form" method="POST" action="/admin/themes/{{theme.id}}/config" style="display:none;"></form>

    {{!-- All fields rendered in manifest order --}}
    <div id="config-fields" style="padding:1rem 1.25rem;">
      {{#each sections}}
      <div style="margin-bottom:1.5rem;">
        <p style="font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#9ca3af;margin-bottom:0.75rem;">{{this.name}}</p>

        {{#each this.fields}}

        {{!-- IMAGE field: own multipart form, inline in section --}}
        {{#if (eq this.type 'image')}}
        <div style="margin-bottom:0.875rem;padding:0.75rem;background:#f9fafb;border:1px solid #e5e7eb;border-radius:0.5rem;">
          <p style="font-size:0.78rem;font-weight:500;color:#374151;margin-bottom:0.5rem;">{{this.label}}</p>
          {{#if this.value}}
          <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.5rem;">
            <div style="height:64px;background:#fff;border:1px solid #e5e7eb;border-radius:0.375rem;overflow:hidden;display:flex;align-items:center;justify-content:center;padding:0.25rem;min-width:80px;">
              <img src="{{this.value}}" alt="" style="max-height:100%;max-width:100%;object-fit:contain;">
            </div>
            <form method="POST" action="/admin/themes/{{../../theme.id}}/config/image/{{this.flatKey}}/remove" style="display:inline;">
              <button type="submit" style="font-size:0.7rem;color:#ef4444;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;">Remove</button>
            </form>
          </div>
          {{/if}}
          <form method="POST" action="/admin/themes/{{../../theme.id}}/config/image/{{this.flatKey}}" enctype="multipart/form-data"
                style="display:flex;gap:0.5rem;align-items:center;">
            <input type="file" name="file" accept="image/*" required
              style="flex:1;font-size:0.72rem;color:#6b7280;min-width:0;">
            <button type="submit"
              style="background:#111827;color:#fff;padding:0.3rem 0.65rem;border-radius:0.375rem;font-size:0.72rem;border:none;cursor:pointer;white-space:nowrap;flex-shrink:0;">
              Upload
            </button>
          </form>
        </div>

        {{!-- REPEATER field: rows of sub-fields, added/removed client-side --}}
        {{else if (eq this.type 'repeater')}}
        <div style="margin-bottom:0.875rem;">
          <p style="font-size:0.78rem;font-weight:500;color:#374151;margin-bottom:0.5rem;">{{this.label}}</p>
          <div id="{{this.containerId}}" class="repeater-container" data-flat-key="{{this.flatKey}}" data-next-index="{{this.nextIndex}}">
            {{#each this.rows}}
            <div class="repeater-row" style="border:1px solid #e5e7eb;border-radius:0.5rem;padding:0.75rem;margin-bottom:0.5rem;background:#f9fafb;">
              {{#each this.cells}}
              <div style="margin-bottom:0.5rem;">
                <label style="display:block;font-size:0.72rem;color:#6b7280;margin-bottom:0.2rem;">{{this.label}}</label>
                {{#if (eq this.type 'select')}}
                <select name="{{this.name}}" form="config-form"
                  style="width:100%;padding:0.3rem 0.4rem;border:1px solid #d1d5db;border-radius:0.375rem;font-size:0.78rem;">
                  {{#each this.options}}
                  <option value="{{this}}" {{#if (eq this ../value)}}selected{{/if}}>{{this}}</option>
                  {{/each}}
                </select>
                {{else if (eq this.type 'collection')}}
                <select name="{{this.name}}" form="config-form"
                  style="width:100%;padding:0.3rem 0.4rem;border:1px solid #d1d5db;border-radius:0.375rem;font-size:0.78rem;">
                  <option value="">All products</option>
                  {{#each this.collectionOptions}}
                  <option value="{{this.slug}}" {{#if (eq this.slug ../value)}}selected{{/if}}>{{this.title}}</option>
                  {{/each}}
                </select>
                {{else}}
                <input type="text" name="{{this.name}}" value="{{this.value}}" form="config-form"
                  style="width:100%;padding:0.3rem 0.4rem;border:1px solid #d1d5db;border-radius:0.375rem;font-size:0.78rem;box-sizing:border-box;">
                {{/if}}
              </div>
              {{/each}}
              <button type="button" class="remove-row-btn"
                style="font-size:0.7rem;color:#ef4444;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;">
                Remove
              </button>
            </div>
            {{/each}}
          </div>
          <button type="button" class="add-row-btn" data-target="{{this.containerId}}" data-item-fields="{{this.itemFieldsJson}}"
            style="font-size:0.75rem;color:#111827;font-weight:500;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:0.375rem;padding:0.35rem 0.65rem;cursor:pointer;">
            + Add
          </button>
        </div>

        {{!-- NON-IMAGE, NON-REPEATER fields: associated with #config-form via HTML5 form attribute --}}
        {{else}}
        <div style="margin-bottom:0.875rem;">
          <label style="display:block;font-size:0.8rem;font-weight:500;color:#374151;margin-bottom:0.3rem;">{{this.label}}</label>

          {{#if (eq this.type 'color')}}
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <input type="color" form="config-form" name="{{this.flatKey}}" value="{{this.value}}"
              id="color-{{this.flatKey}}"
              {{#if this.cssVar}}data-css-var="{{this.cssVar}}"{{/if}}
              style="height:2.25rem;width:3.5rem;border:1px solid #d1d5db;border-radius:0.375rem;cursor:pointer;padding:0.1rem;"
              oninput="document.getElementById('text-{{this.flatKey}}').value=this.value">
            <input type="text" id="text-{{this.flatKey}}" value="{{this.value}}"
              style="width:6rem;padding:0.375rem 0.5rem;border:1px solid #d1d5db;border-radius:0.375rem;font-size:0.8rem;font-family:monospace;"
              oninput="document.getElementById('color-{{this.flatKey}}').value=this.value">
          </div>

          {{else if (eq this.type 'select')}}
          <select form="config-form" name="{{this.flatKey}}"
            {{#if this.cssVar}}data-css-var="{{this.cssVar}}"{{#if this.cssVarIsFont}} data-css-var-type="font"{{/if}}{{/if}}
            style="width:100%;padding:0.375rem 0.5rem;border:1px solid #d1d5db;border-radius:0.375rem;font-size:0.8rem;">
            {{#each this.options}}
            <option value="{{this}}" {{#if (eq this ../value)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>

          {{else if (eq this.type 'boolean')}}
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" form="config-form" name="{{this.flatKey}}" value="true"
              {{#if this.value}}checked{{/if}}>
            <span style="font-size:0.8rem;color:#6b7280;">Enabled</span>
          </label>

          {{else}}
          <input type="text" form="config-form" name="{{this.flatKey}}" value="{{this.value}}"
            style="width:100%;padding:0.375rem 0.5rem;border:1px solid #d1d5db;border-radius:0.375rem;font-size:0.8rem;box-sizing:border-box;">
          {{/if}}
        </div>
        {{/if}}

        {{/each}}
      </div>
      {{/each}}

      <button type="submit" form="config-form"
        style="width:100%;background:#111827;color:#fff;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.85rem;font-weight:500;border:none;cursor:pointer;margin-bottom:0.5rem;"
        onmouseover="this.style.background='#374151'" onmouseout="this.style.background='#111827'">
        Save changes
      </button>
    </div>

    <!-- Theme info -->
    <div style="padding:0.75rem 1.25rem;margin-top:auto;border-top:1px solid #f3f4f6;font-size:0.7rem;color:#9ca3af;line-height:1.6;">
      v{{theme.version}} · {{theme.author}}
    </div>
  </div>

  <!-- ── Preview panel (right) ───────────────────────────────────────────── -->
  <div style="flex:1;display:flex;flex-direction:column;background:#e5e7eb;overflow:hidden;">

    <!-- Preview toolbar -->
    <div style="display:flex;align-items:center;gap:0.75rem;padding:0.5rem 1rem;background:#f9fafb;border-bottom:1px solid #e5e7eb;font-size:0.8rem;">
      <span style="color:#6b7280;font-weight:500;">Preview</span>
      <select id="preview-url-select"
        style="padding:0.25rem 0.5rem;border:1px solid #d1d5db;border-radius:0.375rem;font-size:0.75rem;background:#fff;"
        onchange="navigatePreview(this.value)">
        <option value="/">Homepage</option>
        <option value="/collections/all">All products</option>
        <option value="/cart">Cart</option>
      </select>
      <button onclick="document.getElementById('squaark-preview').src = document.getElementById('squaark-preview').src"
        style="background:none;border:1px solid #d1d5db;border-radius:0.375rem;padding:0.25rem 0.6rem;font-size:0.75rem;cursor:pointer;color:#374151;"
        title="Reload preview">↺ Reload</button>
      <a href="/" target="_blank"
        style="margin-left:auto;color:#6b7280;font-size:0.75rem;text-decoration:none;"
        title="Open in new tab">Open ↗</a>
    </div>

    <!-- iframe + loading overlay -->
    <div style="position:relative;flex:1;overflow:hidden;">
      <iframe id="squaark-preview" src="/"
        style="width:100%;height:100%;border:none;background:#fff;"
        onload="onPreviewLoad()">
      </iframe>
      <div id="preview-loading"
           style="display:none;position:absolute;inset:0;background:rgba(255,255,255,0.6);align-items:center;justify-content:center;pointer-events:none;">
        <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.5rem;padding:0.75rem 1.25rem;font-size:0.8rem;color:#6b7280;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
          Updating preview…
        </div>
      </div>
    </div>
  </div>

</div>

<script>
  var previewReady = false;
  var debounceTimer = null;
  var THEME_ID = '{{theme.id}}';

  // Fields that only need a CSS-var injection (no server round-trip or reload)
  var CSS_VAR_ONLY = new Set(['data-css-var']);
  // Fields that require a full page reload (structural layout changes)
  var RELOAD_FIELDS = new Set([
    'layout.heroPosition', 'layout.heroAlign', 'layout.productsPerRow',
    'layout.heroImage', 'layout.heroImageFit', 'layout.heroImagePadding',
    'layout.showHero', 'layout.featuredSections'
  ]);

  // ── Loading overlay ─────────────────────────────────────────────────────────

  function showLoading() {
    var el = document.getElementById('preview-loading');
    if (el) el.style.display = 'flex';
  }

  function hideLoading() {
    var el = document.getElementById('preview-loading');
    if (el) el.style.display = 'none';
  }

  // ── iframe lifecycle ────────────────────────────────────────────────────────

  function onPreviewLoad() {
    previewReady = true;
    hideLoading();
    injectCssVars();
  }

  function navigatePreview(url) {
    var iframe = document.getElementById('squaark-preview');
    previewReady = false;
    showLoading();
    iframe.src = url;
  }

  function reloadPreviewIframe() {
    var iframe = document.getElementById('squaark-preview');
    var doc = iframe.contentDocument;
    var currentUrl = (doc && doc.location && doc.location.href) ? doc.location.href : '/';
    // Stay on same host — never navigate to an external URL
    if (currentUrl.startsWith('http') && !currentUrl.includes(location.host)) currentUrl = '/';
    previewReady = false;
    showLoading();
    iframe.src = currentUrl;
  }

  // ── CSS-var live injection (instant, no round-trip) ─────────────────────────

  function injectCssVars() {
    var iframe = document.getElementById('squaark-preview');
    var doc = iframe.contentDocument || (iframe.contentWindow && iframe.contentWindow.document);
    if (!doc || !doc.head) return;
    var parts = [];
    document.querySelectorAll('[data-css-var]').forEach(function(el) {
      var isFont = el.dataset.cssVarType === 'font';
      parts.push(el.dataset.cssVar + ':' + (isFont ? "'" + el.value + "',sans-serif" : el.value));
    });
    var s = doc.getElementById('_sq_vars');
    if (!s) { s = doc.createElement('style'); s.id = '_sq_vars'; doc.head.appendChild(s); }
    s.textContent = ':root{' + parts.join(';') + '}';
  }

  // ── Debounced preview-apply (all fields → server re-render) ─────────────────

  function schedulePreview(needsReload) {
    clearTimeout(debounceTimer);
    // Text-only changes use a longer debounce; structural changes reload sooner
    var delay = needsReload ? 600 : 1200;
    debounceTimer = setTimeout(function() { applyPreview(needsReload); }, delay);
  }

  function applyPreview(needsReload) {
    var form = document.getElementById('config-form');
    var body = new URLSearchParams(new FormData(form));
    fetch('/admin/themes/' + THEME_ID + '/preview-apply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: body
    }).then(function(res) {
      if (res.ok && needsReload) reloadPreviewIframe();
    }).catch(function() {
      hideLoading();
    });
  }

  // ── Wire up all inputs ──────────────────────────────────────────────────────

  document.getElementById('config-fields').addEventListener('input', function(e) {
    var el = e.target;
    var fieldName = el.name || '';
    // Instant CSS injection for colour/font fields
    if (el.dataset && el.dataset.cssVar) {
      injectCssVars();
      // CSS vars don't need a reload — just inject and stop
      return;
    }
    // Structural fields need a full reload; text fields just persist to server
    var needsReload = RELOAD_FIELDS.has(fieldName) || fieldName.startsWith('layout.featuredSections');
    schedulePreview(needsReload);
  });

  // Sync hex text input → colour picker (typing a valid hex updates the swatch)
  document.querySelectorAll('[data-css-var][type="color"]').forEach(function(colorEl) {
    var textEl = document.getElementById('text-' + colorEl.name);
    if (!textEl) return;
    textEl.addEventListener('input', function() {
      if (/^#[0-9a-fA-F]{6}$/.test(textEl.value)) colorEl.value = textEl.value;
    });
  });

  // ── Repeater fields: add/remove rows client-side ────────────────────────────

  function addRepeaterRow(addBtn) {
    var container = document.getElementById(addBtn.dataset.target);
    var itemFields = JSON.parse(addBtn.dataset.itemFields);
    var index = parseInt(container.dataset.nextIndex, 10) || 0;
    container.dataset.nextIndex = String(index + 1);
    var flatKey = container.dataset.flatKey;

    var row = document.createElement('div');
    row.className = 'repeater-row';
    row.style.cssText = 'border:1px solid #e5e7eb;border-radius:0.5rem;padding:0.75rem;margin-bottom:0.5rem;background:#f9fafb;';

    Object.keys(itemFields).forEach(function(key) {
      var field = itemFields[key];
      var wrap = document.createElement('div');
      wrap.style.marginBottom = '0.5rem';
      var label = document.createElement('label');
      label.textContent = field.label;
      label.style.cssText = 'display:block;font-size:0.72rem;color:#6b7280;margin-bottom:0.2rem;';
      wrap.appendChild(label);

      var input;
      if (field.type === 'select') {
        input = document.createElement('select');
        (field.options || []).forEach(function(opt) {
          var option = document.createElement('option');
          option.value = opt;
          option.textContent = opt;
          if (opt === field.default) option.selected = true;
          input.appendChild(option);
        });
      } else if (field.type === 'collection') {
        input = document.createElement('select');
        var blankOpt = document.createElement('option');
        blankOpt.value = '';
        blankOpt.textContent = 'All products';
        input.appendChild(blankOpt);
        (window.squaarkCollections || []).forEach(function(col) {
          var option = document.createElement('option');
          option.value = col.slug;
          option.textContent = col.title;
          input.appendChild(option);
        });
      } else {
        input = document.createElement('input');
        input.type = 'text';
        input.value = typeof field.default === 'string' ? field.default : '';
      }
      input.name = flatKey + '[' + index + '][' + key + ']';
      input.setAttribute('form', 'config-form');
      input.style.cssText = 'width:100%;padding:0.3rem 0.4rem;border:1px solid #d1d5db;border-radius:0.375rem;font-size:0.78rem;box-sizing:border-box;';
      wrap.appendChild(input);
      row.appendChild(wrap);
    });

    var removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'remove-row-btn';
    removeBtn.textContent = 'Remove';
    removeBtn.style.cssText = 'font-size:0.7rem;color:#ef4444;background:none;border:none;cursor:pointer;padding:0;text-decoration:underline;';
    row.appendChild(removeBtn);

    container.appendChild(row);
    schedulePreview(true);
  }

  // Selects and checkboxes fire 'change', not 'input'
  document.getElementById('config-fields').addEventListener('change', function(e) {
    var el = e.target;
    if (el.tagName === 'SELECT' || el.type === 'checkbox') {
      schedulePreview(true);
    }
  });

  // Delegated so it covers both server-rendered rows and ones added above
  document.getElementById('config-fields').addEventListener('click', function(e) {
    var addBtn = e.target.closest('.add-row-btn');
    if (addBtn) { addRepeaterRow(addBtn); return; }
    var removeBtn = e.target.closest('.remove-row-btn');
    if (removeBtn) { removeBtn.closest('.repeater-row').remove(); schedulePreview(true); }
  });

  window.squaarkCollections = {{{collectionsJson}}};
</script>
