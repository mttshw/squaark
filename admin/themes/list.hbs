<div class="page-header">
  <h1 class="page-title">Themes</h1>
  <label class="btn btn-primary btn-sm" style="cursor:pointer;">
    Upload theme
    <form id="upload-form" method="POST" action="/admin/themes/upload" enctype="multipart/form-data" style="display:none;">
      <input type="file" name="file" accept=".zip" onchange="document.getElementById('upload-form').submit()">
    </form>
  </label>
</div>

{{#if activated}}<div class="alert alert-success">Theme activated.</div>{{/if}}
{{#if installed}}<div class="alert alert-success">Theme "{{installed}}" installed successfully.</div>{{/if}}
{{#if error}}<div class="alert alert-error">{{error}}</div>{{/if}}

<div class="grid-3">
  {{#each themes}}
  <div class="theme-card {{#if (eq this.active 1)}}theme-card--active{{/if}}">
    <div class="theme-card__header">
      <div>
        <p class="font-semibold">{{this.name}}</p>
        <p class="text-xs text-muted" style="margin-top:0.125rem;">v{{this.version}} · by {{this.author}}</p>
      </div>
      {{#if (eq this.active 1)}}
      <span class="badge badge-green">Active</span>
      {{/if}}
    </div>
    <p class="text-sm text-muted mb-4">{{this.description}}</p>
    <div class="row">
      <a href="/admin/themes/{{this.id}}/config" class="btn btn-secondary btn-sm">Customise</a>
      {{#unless (eq this.active 1)}}
      <form method="POST" action="/admin/themes/{{this.id}}/activate">
        <button type="submit" class="btn btn-primary btn-sm">Activate</button>
      </form>
      {{/unless}}
      <a href="/" target="_blank" class="btn btn-secondary btn-sm">Preview ↗</a>
    </div>
  </div>
  {{/each}}
</div>
