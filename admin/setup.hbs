<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup — Squaark</title>
  <link rel="stylesheet" href="/public/admin.css">
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-card__header">
        <h1 class="auth-card__title">Squaark</h1>
        <p class="auth-card__sub">Create your admin account</p>
      </div>
      <div class="auth-card__body">
        {{#if error}}
        <div class="alert alert-error">{{error}}</div>
        {{/if}}
        <form method="POST" action="/admin/setup" class="auth-form">
          <div>
            <label class="form-label">Name</label>
            <input type="text" name="name" value="{{values.name}}" autofocus class="form-input">
          </div>
          <div>
            <label class="form-label">Email</label>
            <input type="email" name="email" value="{{values.email}}" required class="form-input">
          </div>
          <div>
            <label class="form-label">Password <span class="form-optional">(min 8 chars)</span></label>
            <input type="password" name="password" required minlength="8" class="form-input">
          </div>
          <button type="submit" class="btn btn-primary btn-block">Create account</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
