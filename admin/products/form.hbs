<div class="page-header">
  <div class="page-header__left">
    <a href="/admin/products" class="page-back">← Products</a>
    <h1 class="page-title">{{#if product}}{{product.title}}{{else}}New product{{/if}}</h1>
  </div>
  {{#if product}}
  <form method="POST" action="/admin/products/{{product.id}}/delete" onsubmit="return confirm('Delete this product?')">
    <button type="submit" class="btn-link btn-link--danger btn-link--sm">Delete</button>
  </form>
  {{/if}}
</div>

{{#if error}}<div class="alert alert-error">{{error}}</div>{{/if}}
{{#if saved}}<div class="alert alert-success">Saved.</div>{{/if}}
{{#if created}}<div class="alert alert-success">Product created.</div>{{/if}}

<div class="grid-form">
  <!-- Main form -->
  <div class="stack">
    <form method="POST" action="/admin/products/{{#if product}}{{product.id}}{{else}}new{{/if}}">
      <input type="hidden" name="variant_ids" value="{{#each variants}}{{this.id}}{{#unless @last}},{{/unless}}{{/each}}">

      <div class="card--no-overflow card-body stack-sm">
        <h2 class="font-semibold">Details</h2>
        <div>
          <label class="form-label">Title <span class="form-required">*</span></label>
          <input type="text" name="title" value="{{product.title}}" required class="form-input">
        </div>
        <div>
          <label class="form-label">Slug <span class="form-required">*</span></label>
          <div class="form-prefix">
            <span class="form-prefix-text">/products/</span>
            <input type="text" name="slug" value="{{product.slug}}" required class="form-input flex-1">
          </div>
        </div>
        <div>
          <label class="form-label">Description</label>
          <textarea name="description" rows="5" class="form-textarea">{{product.description}}</textarea>
        </div>
        <div>
          <label class="form-label">Vendor</label>
          <input type="text" name="vendor" value="{{product.vendor}}" class="form-input">
        </div>
        <div>
          <label class="form-label">Tags <span class="form-optional">(comma separated)</span></label>
          <input type="text" name="tags_text" value="{{product.tags_text}}" class="form-input">
        </div>
      </div>

      <!-- Variants -->
      <div class="card--no-overflow card-body stack-sm mt-4">
        <h2 class="font-semibold">{{#if variants.length}}Variants{{else}}Pricing & Inventory{{/if}}</h2>

        {{#if variants.length}}
        {{#each variants}}
        <div style="border:1px solid #f3f4f6;border-radius:0.5rem;padding:1rem;" class="stack-xs">
          <p class="text-sm font-medium">Variant: {{this.title}}</p>
          <div class="form-row form-row--3">
            <div>
              <label class="form-label-xs">Title</label>
              <input type="text" name="variant_title_{{this.id}}" value="{{this.title}}" class="form-input">
            </div>
            <div>
              <label class="form-label-xs">Price (£)</label>
              <input type="number" step="0.01" min="0" name="price_{{this.id}}" value="{{money_pence this.price}}" class="form-input">
            </div>
            <div>
              <label class="form-label-xs">Compare at (£)</label>
              <input type="number" step="0.01" min="0" name="compare_at_price_{{this.id}}" value="{{money_pence this.compare_at_price}}" class="form-input">
            </div>
            <div>
              <label class="form-label-xs">SKU</label>
              <input type="text" name="sku_{{this.id}}" value="{{this.sku}}" class="form-input">
            </div>
            <div>
              <label class="form-label-xs">Inventory</label>
              <input type="number" min="0" name="inventory_quantity_{{this.id}}" value="{{this.inventory_quantity}}" class="form-input">
            </div>
          </div>
        </div>
        {{/each}}
        {{else}}
        <div class="form-row form-row--3">
          <div>
            <label class="form-label-xs">Variant title</label>
            <input type="text" name="variant_title" value="Default" class="form-input">
          </div>
          <div>
            <label class="form-label-xs">Price (£)</label>
            <input type="number" step="0.01" min="0" name="price" value="0.00" class="form-input">
          </div>
          <div>
            <label class="form-label-xs">Compare at (£)</label>
            <input type="number" step="0.01" min="0" name="compare_at_price" class="form-input">
          </div>
          <div>
            <label class="form-label-xs">SKU</label>
            <input type="text" name="sku" class="form-input">
          </div>
          <div>
            <label class="form-label-xs">Inventory</label>
            <input type="number" min="0" name="inventory_quantity" value="0" class="form-input">
          </div>
        </div>
        {{/if}}
      </div>

      <div class="mt-4" style="display:flex;justify-content:flex-end">
        <button type="submit" class="btn btn-primary">
          {{#if product}}Save changes{{else}}Create product{{/if}}
        </button>
      </div>
    </form>

    <!-- Images -->
    {{#if product}}
    <div class="card--no-overflow card-body">
      <h2 class="font-semibold mb-4">Images</h2>
      {{#if uploaded}}
      <div class="alert alert-success">Image uploaded.</div>
      {{/if}}
      <div class="row mb-4" style="flex-wrap:wrap;gap:0.75rem;">
        {{#each images}}
        <div style="position:relative;">
          <img src="{{this.thumbnail}}" alt="{{this.alt}}" style="width:5rem;height:5rem;object-fit:cover;border-radius:0.5rem;border:1px solid #e5e7eb;">
          <form method="POST" action="/admin/products/{{../product.id}}/images/{{this.id}}/delete"
            style="position:absolute;top:0.25rem;right:0.25rem;">
            <button type="submit" title="Remove" class="btn-link btn-link--danger" style="background:#fff;border:1px solid #e5e7eb;border-radius:50%;width:1.25rem;height:1.25rem;display:flex;align-items:center;justify-content:center;font-size:0.75rem;">×</button>
          </form>
        </div>
        {{/each}}
      </div>
      <form method="POST" action="/admin/products/{{product.id}}/images" enctype="multipart/form-data">
        <label class="form-label">Upload image</label>
        <div class="row mt-1">
          <input type="file" name="file" accept="image/*" required class="form-file flex-1">
          <button type="submit" class="btn btn-primary btn-sm">Upload</button>
        </div>
      </form>
    </div>
    {{/if}}
  </div>

  <!-- Sidebar -->
  <div class="stack-sm">
    <div class="card--no-overflow card-body">
      <h2 class="font-semibold mb-3">Status</h2>
      <label class="form-check">
        <input type="checkbox" name="published" value="1" {{#if (eq product.published 1)}}checked{{/if}} form="main-form">
        Published
      </label>
    </div>
    {{#if product}}
    <div class="card--no-overflow card-body text-xs text-muted stack-xs">
      <p>Created {{date_short product.created_at}}</p>
      <p>Updated {{date_short product.updated_at}}</p>
    </div>
    {{/if}}
  </div>
</div>
