<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <a href="/admin/products" class="text-gray-400 hover:text-gray-600 text-sm">← Products</a>
    <h1 class="text-2xl font-bold">{{#if product}}{{product.title}}{{else}}New product{{/if}}</h1>
  </div>
  {{#if product}}
  <form method="POST" action="/admin/products/{{product.id}}/delete" onsubmit="return confirm('Delete this product?')">
    <button type="submit" class="text-red-500 text-sm hover:underline">Delete</button>
  </form>
  {{/if}}
</div>

{{#if error}}
<div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">{{error}}</div>
{{/if}}
{{#if saved}}
<div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Saved.</div>
{{/if}}
{{#if created}}
<div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Product created.</div>
{{/if}}

<div class="grid grid-cols-3 gap-6">
  <!-- Main form -->
  <div class="col-span-2 space-y-5">
    <form method="POST" action="/admin/products/{{#if product}}{{product.id}}{{else}}new{{/if}}">
      <input type="hidden" name="variant_ids" value="{{#each variants}}{{this.id}}{{#unless @last}},{{/unless}}{{/each}}">

      <div class="bg-white rounded-xl border border-gray-200 p-5 space-y-4">
        <h2 class="font-semibold">Details</h2>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
          <input type="text" name="title" value="{{product.title}}" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Slug <span class="text-red-500">*</span></label>
          <div class="flex items-center gap-2">
            <span class="text-gray-400 text-sm">/products/</span>
            <input type="text" name="slug" value="{{product.slug}}" required
              class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea name="description" rows="5"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">{{product.description}}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Vendor</label>
          <input type="text" name="vendor" value="{{product.vendor}}"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tags <span class="text-gray-400 font-normal">(comma separated)</span></label>
          <input type="text" name="tags_text" value="{{product.tags_text}}"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
        </div>
      </div>

      <!-- Variants -->
      <div class="bg-white rounded-xl border border-gray-200 p-5 space-y-4 mt-5">
        <h2 class="font-semibold">{{#if variants.length}}Variants{{else}}Pricing & Inventory{{/if}}</h2>

        {{#if variants.length}}
        {{#each variants}}
        <div class="border border-gray-100 rounded-lg p-4 space-y-3">
          <p class="text-sm font-medium text-gray-700">Variant: {{this.title}}</p>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <label class="block text-xs text-gray-500 mb-1">Title</label>
              <input type="text" name="variant_title_{{this.id}}" value="{{this.title}}"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Price (£)</label>
              <input type="number" step="0.01" min="0" name="price_{{this.id}}" value="{{money_pence this.price}}"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Compare at (£)</label>
              <input type="number" step="0.01" min="0" name="compare_at_price_{{this.id}}" value="{{money_pence this.compare_at_price}}"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">SKU</label>
              <input type="text" name="sku_{{this.id}}" value="{{this.sku}}"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
            <div>
              <label class="block text-xs text-gray-500 mb-1">Inventory</label>
              <input type="number" min="0" name="inventory_quantity_{{this.id}}" value="{{this.inventory_quantity}}"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
          </div>
        </div>
        {{/each}}
        {{else}}
        <div class="grid grid-cols-3 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Variant title</label>
            <input type="text" name="variant_title" value="Default"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Price (£)</label>
            <input type="number" step="0.01" min="0" name="price" value="0.00"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Compare at (£)</label>
            <input type="number" step="0.01" min="0" name="compare_at_price"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">SKU</label>
            <input type="text" name="sku"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Inventory</label>
            <input type="number" min="0" name="inventory_quantity" value="0"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
        </div>
        {{/if}}
      </div>

      <div class="mt-5 flex justify-end">
        <button type="submit" class="bg-gray-900 text-white px-6 py-2 rounded-lg text-sm font-medium hover:bg-gray-700">
          {{#if product}}Save changes{{else}}Create product{{/if}}
        </button>
      </div>
    </form>

    <!-- Images -->
    {{#if product}}
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold mb-4">Images</h2>
      {{#if uploaded}}
      <div class="mb-3 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Image uploaded.</div>
      {{/if}}
      <div class="flex flex-wrap gap-3 mb-4">
        {{#each images}}
        <div class="relative group">
          <img src="{{this.thumbnail}}" alt="{{this.alt}}" class="w-20 h-20 object-cover rounded-lg border border-gray-200">
          <form method="POST" action="/admin/products/{{../product.id}}/images/{{this.id}}/delete"
            class="absolute top-1 right-1 hidden group-hover:block">
            <button type="submit" title="Remove"
              class="bg-white border border-gray-200 rounded-full w-5 h-5 text-red-500 text-xs leading-none flex items-center justify-center hover:bg-red-50">×</button>
          </form>
        </div>
        {{/each}}
      </div>
      <form method="POST" action="/admin/products/{{product.id}}/images" enctype="multipart/form-data">
        <label class="block text-sm font-medium text-gray-700 mb-1">Upload image</label>
        <div class="flex gap-2">
          <input type="file" name="file" accept="image/*" required
            class="flex-1 text-sm text-gray-500 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200">
          <button type="submit" class="bg-gray-900 text-white px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-700">Upload</button>
        </div>
      </form>
    </div>
    {{/if}}
  </div>

  <!-- Sidebar -->
  <div class="space-y-4">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold mb-3">Status</h2>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" name="published" value="1" {{#if (eq product.published 1)}}checked{{/if}}
          form="main-form" class="rounded">
        Published
      </label>
    </div>
    {{#if product}}
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-xs text-gray-400 space-y-1">
      <p>Created {{date_short product.created_at}}</p>
      <p>Updated {{date_short product.updated_at}}</p>
    </div>
    {{/if}}
  </div>
</div>
