<div class="page-header">
  <h1 class="page-title">Products</h1>
  <a href="/admin/products/new" class="btn btn-primary btn-sm">Add product</a>
</div>

{{#if deleted}}
<div class="alert alert-success">Product deleted.</div>
{{/if}}

<div class="card">
  {{#if products.length}}
  <table class="data-table">
    <thead>
      <tr>
        <th>Product</th>
        <th>Status</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each products}}
      <tr>
        <td>
          <a href="/admin/products/{{this.id}}" class="cell-title">{{this.title}}</a>
          <p class="cell-hint">/products/{{this.slug}}</p>
        </td>
        <td>
          {{#if (eq this.published 1)}}
          <span class="badge badge-green">Active</span>
          {{else}}
          <span class="badge badge-gray">Draft</span>
          {{/if}}
        </td>
        <td class="text-muted text-xs">{{date_short this.created_at}}</td>
        <td class="right"><a href="/admin/products/{{this.id}}" class="cell-action">Edit →</a></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state">
    <p>No products yet.</p>
    <a href="/admin/products/new">Add your first product</a>
  </div>
  {{/if}}
</div>

{{#if (gt totalPages 1)}}
<div class="admin-pagination mt-4">
  {{#if (gt page 1)}}
  <a href="/admin/products?page={{subtract page 1}}">← Previous</a>
  {{else}}<span></span>{{/if}}
  <span class="admin-pagination__info">Page {{page}} of {{totalPages}}</span>
  {{#if (lt page totalPages)}}
  <a href="/admin/products?page={{add page 1}}">Next →</a>
  {{else}}<span></span>{{/if}}
</div>
{{/if}}
