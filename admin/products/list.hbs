<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Products</h1>
  <a href="/admin/products/new" class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-700">Add product</a>
</div>

{{#if deleted}}
<div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Product deleted.</div>
{{/if}}

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  {{#if products.length}}
  <table class="w-full text-sm">
    <thead class="border-b border-gray-100 bg-gray-50">
      <tr>
        <th class="text-left px-4 py-3 font-medium text-gray-500">Product</th>
        <th class="text-left px-4 py-3 font-medium text-gray-500">Status</th>
        <th class="text-left px-4 py-3 font-medium text-gray-500">Created</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {{#each products}}
      <tr class="hover:bg-gray-50">
        <td class="px-4 py-3 font-medium">
          <a href="/admin/products/{{this.id}}" class="hover:underline">{{this.title}}</a>
          <p class="text-xs text-gray-400 font-normal">/products/{{this.slug}}</p>
        </td>
        <td class="px-4 py-3">
          {{#if (eq this.published 1)}}
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Active</span>
          {{else}}
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">Draft</span>
          {{/if}}
        </td>
        <td class="px-4 py-3 text-gray-500">{{date_short this.created_at}}</td>
        <td class="px-4 py-3 text-right">
          <a href="/admin/products/{{this.id}}" class="text-gray-400 hover:text-gray-700 text-xs">Edit →</a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="px-4 py-12 text-center text-gray-400">
    <p class="mb-3">No products yet.</p>
    <a href="/admin/products/new" class="text-gray-900 font-medium underline">Add your first product</a>
  </div>
  {{/if}}
</div>

{{#if (gt totalPages 1)}}
<div class="flex justify-between mt-4 text-sm">
  {{#if (gt page 1)}}
  <a href="/admin/products?page={{subtract page 1}}" class="text-gray-600 hover:underline">← Previous</a>
  {{else}}<span></span>{{/if}}
  <span class="text-gray-400">Page {{page}} of {{totalPages}}</span>
  {{#if (lt page totalPages)}}
  <a href="/admin/products?page={{add page 1}}" class="text-gray-600 hover:underline">Next →</a>
  {{else}}<span></span>{{/if}}
</div>
{{/if}}
