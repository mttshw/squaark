<div class="page-header">
  <h1 class="page-title">Pages</h1>
  <a href="/admin/pages/new" class="btn btn-primary btn-sm">Add page</a>
</div>

<div class="card">
  {{#if pages.length}}
  <table class="data-table">
    <thead>
      <tr>
        <th>Page</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each pages}}
      <tr>
        <td>
          <a href="/admin/pages/{{this.id}}" class="cell-title">{{this.title}}</a>
          <p class="cell-hint">/{{this.slug}}</p>
        </td>
        <td>
          {{#if (eq this.status 'published')}}
          <span class="badge badge-green">Published</span>
          {{else}}
          <span class="badge badge-gray">Draft</span>
          {{/if}}
        </td>
        <td class="right"><a href="/admin/pages/{{this.id}}" class="cell-action">Edit →</a></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state">
    <p>No pages yet.</p>
    <a href="/admin/pages/new">Create your first page</a>
  </div>
  {{/if}}
</div>
