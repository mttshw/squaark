<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Pages</h1>
  <a href="/admin/pages/new" class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-700">Add page</a>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  {{#if pages.length}}
  <table class="w-full text-sm">
    <thead class="border-b border-gray-100 bg-gray-50">
      <tr>
        <th class="text-left px-4 py-3 font-medium text-gray-500">Page</th>
        <th class="text-left px-4 py-3 font-medium text-gray-500">Status</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {{#each pages}}
      <tr class="hover:bg-gray-50">
        <td class="px-4 py-3 font-medium">
          <a href="/admin/pages/{{this.id}}" class="hover:underline">{{this.title}}</a>
          <p class="text-xs text-gray-400 font-normal">/{{this.slug}}</p>
        </td>
        <td class="px-4 py-3">
          {{#if (eq this.status 'published')}}
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Published</span>
          {{else}}
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">Draft</span>
          {{/if}}
        </td>
        <td class="px-4 py-3 text-right">
          <a href="/admin/pages/{{this.id}}" class="text-gray-400 hover:text-gray-700 text-xs">Edit →</a>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="px-4 py-12 text-center text-gray-400">
    <p class="mb-3">No pages yet.</p>
    <a href="/admin/pages/new" class="text-gray-900 font-medium underline">Create your first page</a>
  </div>
  {{/if}}
</div>
