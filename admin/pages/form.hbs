<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <a href="/admin/pages" class="text-gray-400 hover:text-gray-600 text-sm">← Pages</a>
    <h1 class="text-2xl font-bold">{{#if page}}{{page.title}}{{else}}New page{{/if}}</h1>
  </div>
  {{#if page}}
  <form method="POST" action="/admin/pages/{{page.id}}/delete" onsubmit="return confirm('Delete this page?')">
    <button type="submit" class="text-red-500 text-sm hover:underline">Delete</button>
  </form>
  {{/if}}
</div>

{{#if error}}<div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">{{error}}</div>{{/if}}
{{#if saved}}<div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Saved.</div>{{/if}}
{{#if created}}<div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">Page created.</div>{{/if}}

<form method="POST" action="/admin/pages/{{#if page}}{{page.id}}{{else}}new{{/if}}">

  <div class="grid grid-cols-3 gap-6">
    <div class="col-span-2 space-y-5">

      <!-- Details -->
      <div class="bg-white rounded-xl border border-gray-200 p-5 space-y-4">
        <h2 class="font-semibold">Details</h2>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
          <input type="text" name="title" value="{{page.title}}" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Slug <span class="text-red-500">*</span></label>
          <div class="flex items-center gap-2">
            <span class="text-gray-400 text-sm">/</span>
            <input type="text" name="slug" value="{{page.slug}}" required
              class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Excerpt <span class="text-gray-400 font-normal text-xs">— shown in search results and meta descriptions</span></label>
          <textarea name="excerpt" rows="2"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">{{page.excerpt}}</textarea>
        </div>
      </div>

      <!-- Section builder -->
      <div class="bg-white rounded-xl border border-gray-200 p-5"
           x-data="sectionBuilder('{{page.id}}')"
           x-init="init($el.dataset.sections)"
           data-sections='{{sectionsSafe}}'>

        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold">Page sections</h2>
          <div class="relative" x-data="{ open: false }">
            <button type="button" @click="open = !open"
              class="flex items-center gap-1 bg-gray-900 text-white text-sm px-3 py-1.5 rounded-lg hover:bg-gray-700">
              + Add section
              <svg class="w-3 h-3 ml-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div x-show="open" @click.outside="open = false" x-cloak
              class="absolute right-0 mt-1 w-44 bg-white border border-gray-200 rounded-xl shadow-lg z-10 py-1 text-sm">
              <button type="button" @click="add('text'); open = false" class="w-full text-left px-4 py-2 hover:bg-gray-50">Text</button>
              <button type="button" @click="add('image'); open = false" class="w-full text-left px-4 py-2 hover:bg-gray-50">Image</button>
              <button type="button" @click="add('image_text'); open = false" class="w-full text-left px-4 py-2 hover:bg-gray-50">Image + Text</button>
              <button type="button" @click="add('cta'); open = false" class="w-full text-left px-4 py-2 hover:bg-gray-50">Call to Action</button>
              <button type="button" @click="add('columns'); open = false" class="w-full text-left px-4 py-2 hover:bg-gray-50">Two Columns</button>
            </div>
          </div>
        </div>

        <!-- Empty state -->
        <div x-show="sections.length === 0"
          class="border-2 border-dashed border-gray-200 rounded-xl py-12 text-center text-sm text-gray-400">
          No sections yet. Add one above to start building this page.
          {{#if page.content}}<p class="mt-2 text-xs">This page has legacy content that will show until sections are added.</p>{{/if}}
        </div>

        <!-- Section cards -->
        <template x-for="(s, i) in sections" :key="s.id">
          <div class="border border-gray-200 rounded-xl mb-3 overflow-hidden">

            <!-- Card header -->
            <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-50 border-b border-gray-100">
              <span class="text-sm font-medium text-gray-700" x-text="LABELS[s.type]"></span>
              <div class="ml-auto flex items-center gap-1">
                <button type="button" @click="moveUp(i)" :disabled="i === 0"
                  class="p-1 rounded text-gray-400 hover:text-gray-700 disabled:opacity-30" title="Move up">↑</button>
                <button type="button" @click="moveDown(i)" :disabled="i === sections.length - 1"
                  class="p-1 rounded text-gray-400 hover:text-gray-700 disabled:opacity-30" title="Move down">↓</button>
                <button type="button" @click="remove(i)"
                  class="p-1 rounded text-gray-400 hover:text-red-600 ml-1" title="Remove">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
                <button type="button" @click="s._open = !s._open"
                  class="p-1 rounded text-gray-400 hover:text-gray-700 ml-1">
                  <svg class="w-4 h-4 transition-transform" :class="s._open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Card body -->
            <div x-show="s._open" class="p-4 space-y-3">

              <!-- TEXT -->
              <template x-if="s.type === 'text'">
                <div>
                  <label class="block text-xs font-medium text-gray-600 mb-1">Content <span class="font-normal text-gray-400">(HTML)</span></label>
                  <textarea x-model="s.content" rows="8"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-gray-900"
                    placeholder="<p>Your text here...</p>"></textarea>
                </div>
              </template>

              <!-- IMAGE -->
              <template x-if="s.type === 'image'">
                <div class="space-y-3">
                  <div x-show="s.src" class="flex items-start gap-3">
                    <img :src="s.src" class="h-24 rounded-lg object-contain border border-gray-200 bg-gray-50 p-1">
                    <button type="button" @click="s.src = ''" class="text-xs text-red-500 hover:underline mt-1">Remove</button>
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Upload image</label>
                    <template x-if="!pageId">
                      <p class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded-lg p-2">Save the page first to enable image uploads.</p>
                    </template>
                    <template x-if="pageId">
                      <input type="file" accept="image/*" @change="uploadImage(i, $event)"
                        class="text-sm text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-900 file:text-white hover:file:bg-gray-700">
                    </template>
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Alt text</label>
                    <input x-model="s.alt" type="text" placeholder="Describe the image"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Caption <span class="font-normal text-gray-400">(optional)</span></label>
                    <input x-model="s.caption" type="text" placeholder="Optional caption shown below image"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                  </div>
                </div>
              </template>

              <!-- IMAGE + TEXT -->
              <template x-if="s.type === 'image_text'">
                <div class="space-y-3">
                  <div x-show="s.src" class="flex items-start gap-3">
                    <img :src="s.src" class="h-24 rounded-lg object-contain border border-gray-200 bg-gray-50 p-1">
                    <button type="button" @click="s.src = ''" class="text-xs text-red-500 hover:underline mt-1">Remove</button>
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Upload image</label>
                    <template x-if="!pageId">
                      <p class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded-lg p-2">Save the page first to enable image uploads.</p>
                    </template>
                    <template x-if="pageId">
                      <input type="file" accept="image/*" @change="uploadImage(i, $event)"
                        class="text-sm text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-900 file:text-white hover:file:bg-gray-700">
                    </template>
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Alt text</label>
                    <input x-model="s.alt" type="text"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Image position</label>
                    <select x-model="s.imagePosition"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                      <option value="left">Left</option>
                      <option value="right">Right</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Text content <span class="font-normal text-gray-400">(HTML)</span></label>
                    <textarea x-model="s.content" rows="6"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-gray-900"
                      placeholder="<p>Your text here...</p>"></textarea>
                  </div>
                </div>
              </template>

              <!-- CTA -->
              <template x-if="s.type === 'cta'">
                <div class="space-y-3">
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Heading</label>
                    <input x-model="s.heading" type="text" placeholder="Ready to get started?"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Body text</label>
                    <textarea x-model="s.body" rows="3" placeholder="Supporting paragraph..."
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900"></textarea>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Button label</label>
                      <input x-model="s.buttonLabel" type="text" placeholder="Shop Now"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Button URL</label>
                      <input x-model="s.buttonUrl" type="text" placeholder="/collections/all"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                    </div>
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Alignment</label>
                    <select x-model="s.align"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                      <option value="center">Center</option>
                      <option value="left">Left</option>
                    </select>
                  </div>
                </div>
              </template>

              <!-- COLUMNS -->
              <template x-if="s.type === 'columns'">
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Left column <span class="font-normal text-gray-400">(HTML)</span></label>
                    <textarea x-model="s.leftContent" rows="8"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-gray-900"
                      placeholder="<p>Left column content...</p>"></textarea>
                  </div>
                  <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Right column <span class="font-normal text-gray-400">(HTML)</span></label>
                    <textarea x-model="s.rightContent" rows="8"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-gray-900"
                      placeholder="<p>Right column content...</p>"></textarea>
                  </div>
                </div>
              </template>

            </div>
          </div>
        </template>

        <!-- Hidden field — submitted with the main form -->
        <input type="hidden" name="sections" :value="JSON.stringify(sections.map(({_open, ...rest}) => rest))">
      </div>

      <!-- Preserve legacy content (WooCommerce imports) as hidden field -->
      {{#if page.content}}<input type="hidden" name="content" value="{{page.content}}">{{/if}}

    </div>

    <!-- Sidebar -->
    <div class="space-y-4">
      <div class="bg-white rounded-xl border border-gray-200 p-4 space-y-4">
        <h2 class="font-semibold text-sm">Publish</h2>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" name="status" value="published" {{#if (eq page.status 'published')}}checked{{/if}} class="rounded">
          Published
        </label>
        <button type="submit" class="w-full bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-700">
          {{#if page}}Save changes{{else}}Create page{{/if}}
        </button>
        {{#if page}}
        <a href="/{{page.slug}}" target="_blank" class="block text-center text-xs text-gray-400 hover:text-gray-700">View page ↗</a>
        {{/if}}
      </div>
      {{#if page}}
      <div class="bg-white rounded-xl border border-gray-200 p-4 text-xs text-gray-400 space-y-1">
        <p>Created {{date_short page.created_at}}</p>
        <p>Updated {{date_short page.updated_at}}</p>
      </div>
      {{/if}}
    </div>
  </div>

</form>

<script>
function sectionBuilder(pageId) {
  return {
    pageId: pageId || '',
    sections: [],
    LABELS: {
      text: 'Text',
      image: 'Image',
      image_text: 'Image + Text',
      cta: 'Call to Action',
      columns: 'Two Columns'
    },
    DEFAULTS: {
      text:       { content: '' },
      image:      { src: '', alt: '', caption: '' },
      image_text: { src: '', alt: '', content: '', imagePosition: 'left' },
      cta:        { heading: '', body: '', buttonLabel: 'Shop Now', buttonUrl: '/collections/all', align: 'center' },
      columns:    { leftContent: '', rightContent: '' }
    },
    init(sectionsJson) {
      try {
        const parsed = JSON.parse(sectionsJson || '[]');
        this.sections = parsed.map(s => ({ ...s, _open: true }));
      } catch { this.sections = []; }
    },
    add(type) {
      this.sections.push({ id: crypto.randomUUID(), type, _open: true, ...(this.DEFAULTS[type] || {}) });
    },
    remove(index) {
      if (confirm('Remove this section?')) this.sections.splice(index, 1);
    },
    moveUp(index) {
      if (index === 0) return;
      [this.sections[index - 1], this.sections[index]] = [this.sections[index], this.sections[index - 1]];
      this.sections = [...this.sections];
    },
    moveDown(index) {
      if (index === this.sections.length - 1) return;
      [this.sections[index], this.sections[index + 1]] = [this.sections[index + 1], this.sections[index]];
      this.sections = [...this.sections];
    },
    async uploadImage(index, event) {
      const file = event.target.files[0];
      if (!file || !this.pageId) return;
      const fd = new FormData();
      fd.append('file', file);
      const res = await fetch('/admin/pages/' + this.pageId + '/sections/image', { method: 'POST', body: fd });
      if (res.ok) {
        const data = await res.json();
        this.sections[index].src = data.url;
        this.sections = [...this.sections];
      }
    }
  };
}
</script>
