<article class="group">
  <a href="{{url 'product' this.slug}}" class="block">
    <!-- Image -->
    <div class="product-image-wrap aspect-[3/4] bg-gray-50 rounded-lg overflow-hidden mb-4">
      {{#if this.image}}
        <img src="{{this.image.medium}}"
             srcset="{{this.image.thumbnail}} 200w, {{this.image.medium}} 600w"
             sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
             alt="{{this.image.alt}}"
             loading="lazy"
             class="w-full h-full object-cover">
      {{else}}
        <div class="w-full h-full flex items-center justify-center text-gray-300">
          <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M14 8h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      {{/if}}

      <!-- Badges -->
      <div class="absolute top-3 left-3 flex flex-col gap-1">
        {{#if this.onSale}}
          <span class="badge-sale">Sale</span>
        {{/if}}
        {{#unless this.available}}
          <span class="badge-sale" style="background:#6b7280">Sold Out</span>
        {{/unless}}
      </div>
    </div>

    <!-- Info -->
    <div class="space-y-1">
      {{#if this.vendor}}
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wider">{{this.vendor}}</p>
      {{/if}}
      <h3 class="text-sm font-semibold text-gray-900 group-hover:text-accent transition-colors leading-tight" style="--tw-text-opacity:1">
        {{this.title}}
      </h3>
      <div class="flex items-baseline gap-2">
        <span class="text-sm font-bold {{#if this.onSale}}text-accent{{else}}text-gray-900{{/if}}" style="{{#if this.onSale}}color:var(--color-accent){{/if}}">
          {{money this.price}}
        </span>
        {{#if this.compareAtPrice}}
          <span class="text-xs text-gray-400 line-through">{{money this.compareAtPrice}}</span>
        {{/if}}
      </div>
    </div>
  </a>
</article>
