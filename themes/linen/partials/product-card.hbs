<article class="product-card">
  <a href="{{url 'product' this.slug}}" style="display:block;">
    <!-- Image -->
    <div class="product-card__image-wrap">
      {{#if this.image}}
        <img src="{{this.image.medium}}"
             srcset="{{this.image.thumbnail}} 200w, {{this.image.medium}} 600w"
             sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
             alt="{{this.image.alt}}"
             loading="lazy">
      {{else}}
        <div class="product-card__placeholder">
          <svg width="64" height="64" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M14 8h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      {{/if}}

      <!-- Badges -->
      <div class="product-card__badges">
        {{#if this.onSale}}
          <span class="badge-sale">Sale</span>
        {{/if}}
        {{#unless this.available}}
          <span class="badge-sale" style="background:#6b7280">Sold Out</span>
        {{/unless}}
      </div>
    </div>

    <!-- Info -->
    <div class="product-card__info">
      {{#if this.vendor}}
        <p class="product-card__vendor">{{this.vendor}}</p>
      {{/if}}
      <h3 class="product-card__title">{{this.title}}</h3>
      <div class="product-card__prices">
        <span class="product-card__price {{#if this.onSale}}product-card__price--sale{{/if}}">
          {{money this.price}}
        </span>
        {{#if this.compareAtPrice}}
          <span class="product-card__compare">{{money this.compareAtPrice}}</span>
        {{/if}}
      </div>
    </div>
  </a>
</article>
