<div class="w-full py-20 px-4" style="background:var(--color-primary)">
  <div class="max-w-3xl mx-auto {{#if (eq align 'center')}}text-center{{else}}text-left{{/if}}">
    {{#if heading}}<h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">{{heading}}</h2>{{/if}}
    {{#if body}}<p class="text-white opacity-75 mb-8 text-lg leading-relaxed">{{body}}</p>{{/if}}
    {{#if buttonLabel}}
    <a href="{{buttonUrl}}" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-semibold"
       style="background:var(--color-accent);color:white">
      {{buttonLabel}}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
    {{/if}}
  </div>
</div>
