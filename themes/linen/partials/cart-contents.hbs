<div id="cart-contents">
  {{#unless cart.empty}}
    <div class="divide-y divide-gray-100">
      {{#each cart.items}}
        <div class="py-5 flex gap-4 items-start">

          <!-- Image -->
          <a href="{{url 'product' this.productSlug}}" class="flex-shrink-0">
            <div class="w-24 h-24 rounded-xl overflow-hidden bg-gray-100">
              <img src="{{this.image.thumbnail}}" alt="{{this.productTitle}}" class="w-full h-full object-cover">
            </div>
          </a>

          <!-- Details -->
          <div class="flex-1 min-w-0">
            <a href="{{url 'product' this.productSlug}}"
               class="font-medium text-sm text-gray-900 hover:underline leading-snug block">
              {{this.productTitle}}
            </a>
            {{#unless (is this.variantTitle "Default")}}
              <p class="text-xs text-gray-400 mt-0.5">{{this.variantTitle}}</p>
            {{/unless}}
            <p class="text-sm font-semibold text-gray-900 mt-2">{{money this.lineTotal}}</p>

            <!-- Quantity + remove (below product info on mobile) -->
            <div class="flex items-center gap-3 mt-3">
              <div class="flex items-center border border-gray-200 rounded-lg overflow-hidden">
                <button type="button" onclick="stepQty(this, -1)"
                        class="px-3 py-1.5 text-gray-500 hover:bg-gray-50 text-sm leading-none">−</button>
                <input type="number" value="{{this.quantity}}" min="1"
                       hx-post="/{{../store.cartSlug}}/update"
                       hx-target="#cart-contents"
                       hx-swap="outerHTML"
                       hx-vals='{"itemId": "{{this.id}}"}'
                       hx-trigger="change"
                       name="quantity"
                       class="w-10 text-center text-sm border-x border-gray-200 py-1.5 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                <button type="button" onclick="stepQty(this, 1)"
                        class="px-3 py-1.5 text-gray-500 hover:bg-gray-50 text-sm leading-none">+</button>
              </div>

              <button hx-delete="/{{../store.cartSlug}}/remove/{{this.id}}"
                      hx-target="#cart-contents"
                      hx-swap="outerHTML"
                      class="text-xs text-gray-400 hover:text-red-500 transition-colors">
                Remove
              </button>
            </div>
          </div>

        </div>
      {{/each}}
    </div>
  {{/unless}}
</div>

<script>
function stepQty(btn, delta) {
  const input = btn.parentElement.querySelector('input[type=number]');
  const next = Math.max(1, parseInt(input.value || '1') + delta);
  input.value = next;
  input.dispatchEvent(new Event('change'));
}
</script>
