<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {{meta_title}}
  {{meta_description}}
  {{canonical_url}}
  {{#if store.icon}}
  <link rel="icon" href="{{store.icon}}">
  {{else}}
  <link rel="icon" href="data:,">
  {{/if}}
  <link rel="stylesheet" href="{{asset 'style.css'}}">
  {{{cssVars}}}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/htmx.org@2.0.3" defer></script>
  <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</head>
<body>

<header class="site-header">
  <div class="site-header__inner">

    <!-- Logo / Store name -->
    <a href="/" class="site-header__logo">
      {{#if store.logo}}
        <img src="{{store.logo}}" alt="{{store.name}}" style="height:2rem;width:auto;">
      {{else}}
        <span>{{store.name}}</span>
      {{/if}}
    </a>

    <!-- Main navigation -->
    <nav class="header-nav">
      {{#each navigation.main}}
        <a href="{{this.url}}" class="{{#is this.url ../currentPath}}active{{/is}}">{{this.label}}</a>
      {{/each}}
    </nav>

    <!-- Right actions -->
    <div class="header-actions">

      <!-- Account -->
      {{#if store.customerAccountsEnabled}}
      <a href="/account" class="header-icon" aria-label="{{#if customer.loggedIn}}My account{{else}}Sign in{{/if}}">
        {{#if customer.loggedIn}}
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm0 2c-5.33 0-8 2.67-8 4v1h16v-1c0-1.33-2.67-4-8-4z"/>
        </svg>
        {{else}}
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0zM12 14a7 7 0 0 0-7 7h14a7 7 0 0 0-7-7z"/>
        </svg>
        {{/if}}
      </a>
      {{/if}}

      <!-- Search -->
      <a href="/search" class="header-icon" aria-label="Search">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
      </a>

      <!-- Cart -->
      <a href="/{{store.cartSlug}}" class="header-icon" style="position:relative;" aria-label="{{store.cartLabel}}">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M16 11V7a4 4 0 0 0-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        <span id="cart-count" class="cart-badge"
              style="{{#unless cart.itemCount}}display:none{{/unless}}">
          {{cart.itemCount}}
        </span>
      </a>

      <!-- Mobile menu toggle -->
      <button class="mobile-menu-btn" x-data @click="$dispatch('toggle-menu')" aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile nav -->
  <div class="mobile-nav" x-data="{ open: false }" @toggle-menu.window="open = !open" x-show="open" x-cloak>
    <div class="mobile-nav__inner">
      {{#each navigation.main}}
        <a href="{{this.url}}">{{this.label}}</a>
      {{/each}}
    </div>
  </div>
</header>

<main>
