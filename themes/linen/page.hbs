{{> header}}

<div class="container--narrow page-title-area">
  <h1>{{page.title}}</h1>
</div>

{{#if page.sections}}
  {{#each page.sections}}
  {{renderSection this}}
  {{/each}}
{{else}}
  <div class="container--narrow" style="padding-bottom:4rem;">
    <div class="cms-prose">
      {{{page.content}}}
    </div>
  </div>
{{/if}}

{{> footer}}
