{{> header}}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Checkout</h1>

  <div class="lg:grid lg:grid-cols-5 lg:gap-12">

    <!-- Address + payment form -->
    <div class="lg:col-span-3 space-y-8">

      <!-- Contact -->
      <div>
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4">Contact</h2>
        <div>
          <label class="block text-sm text-gray-600 mb-1">Email address</label>
          <input type="email" id="email" name="email" required autocomplete="email"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
        </div>
      </div>

      <!-- Shipping address -->
      <div>
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4">Shipping address</h2>
        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm text-gray-600 mb-1">First name</label>
              <input type="text" id="firstName" name="firstName" required autocomplete="given-name"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
            <div>
              <label class="block text-sm text-gray-600 mb-1">Last name</label>
              <input type="text" id="lastName" name="lastName" required autocomplete="family-name"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-1">Address line 1</label>
            <input type="text" id="line1" name="line1" required autocomplete="address-line1"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-1">Address line 2 <span class="text-gray-400">(optional)</span></label>
            <input type="text" id="line2" name="line2" autocomplete="address-line2"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm text-gray-600 mb-1">Town / City</label>
              <input type="text" id="city" name="city" required autocomplete="address-level2"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
            <div>
              <label class="block text-sm text-gray-600 mb-1">County <span class="text-gray-400">(optional)</span></label>
              <input type="text" id="county" name="county" autocomplete="address-level1"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm text-gray-600 mb-1">Postcode</label>
              <input type="text" id="postcode" name="postcode" required autocomplete="postal-code"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
            </div>
            <div>
              <label class="block text-sm text-gray-600 mb-1">Country</label>
              <select id="country" name="country" required autocomplete="country"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
                <option value="GB" selected>United Kingdom</option>
                <option value="US">United States</option>
                <option value="AU">Australia</option>
                <option value="CA">Canada</option>
                <option value="IE">Ireland</option>
                <option value="NZ">New Zealand</option>
                <option value="FR">France</option>
                <option value="DE">Germany</option>
                <option value="NL">Netherlands</option>
                <option value="SE">Sweden</option>
                <option value="NO">Norway</option>
                <option value="DK">Denmark</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-sm text-gray-600 mb-1">Phone <span class="text-gray-400">(optional)</span></label>
            <input type="tel" id="phone" name="phone" autocomplete="tel"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
          </div>
        </div>
      </div>

      <!-- Payment -->
      <div>
        <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4">Payment</h2>

        <div id="payment-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>

        {{#if stripeEnabled}}
          <!-- Stripe: standard form POST -->
          <form method="POST" action="/checkout" id="stripe-form">
            <input type="hidden" name="email" id="stripe-email">
            <input type="hidden" name="firstName" id="stripe-firstName">
            <input type="hidden" name="lastName" id="stripe-lastName">
            <input type="hidden" name="line1" id="stripe-line1">
            <input type="hidden" name="line2" id="stripe-line2">
            <input type="hidden" name="city" id="stripe-city">
            <input type="hidden" name="county" id="stripe-county">
            <input type="hidden" name="postcode" id="stripe-postcode">
            <input type="hidden" name="country" id="stripe-country">
            <input type="hidden" name="phone" id="stripe-phone">
            <button type="button" onclick="submitStripe()"
              class="w-full py-3.5 px-6 text-sm font-semibold text-white rounded-xl hover:opacity-90 transition-all mb-3"
              style="background:var(--color-accent)">
              Pay by Card
            </button>
          </form>
        {{/if}}

        {{#if paypalEnabled}}
          <div id="paypal-button-container"></div>
        {{/if}}

        {{#unless stripeEnabled}}{{#unless paypalEnabled}}
          <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
            No payment methods are configured yet. Add Stripe or PayPal keys in
            <a href="/admin/settings#payments" class="underline">Settings → Payments</a>.
          </div>
        {{/unless}}{{/unless}}
      </div>

    </div>

    <!-- Order summary -->
    <div class="lg:col-span-2 mt-10 lg:mt-0">
      <div class="rounded-2xl border border-gray-100 bg-gray-50 p-6 sticky top-24">
        <h2 class="font-semibold text-gray-900 mb-5">Order summary</h2>

        <div class="divide-y divide-gray-100 mb-5">
          {{#each cart.items}}
            <div class="py-3 flex gap-3 items-center">
              <div class="w-12 h-12 rounded-lg overflow-hidden bg-gray-200 flex-shrink-0">
                <img src="{{this.image.thumbnail}}" alt="{{this.productTitle}}" class="w-full h-full object-cover">
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate">{{this.productTitle}}</p>
                {{#unless (is this.variantTitle "Default")}}
                  <p class="text-xs text-gray-400">{{this.variantTitle}}</p>
                {{/unless}}
                <p class="text-xs text-gray-500">Qty {{this.quantity}}</p>
              </div>
              <p class="text-sm font-medium text-gray-900 flex-shrink-0">{{money this.lineTotal}}</p>
            </div>
          {{/each}}
        </div>

        <div class="space-y-2 text-sm border-t border-gray-200 pt-4">
          <div class="flex justify-between text-gray-600">
            <span>Subtotal</span>
            <span>{{money cart.subtotal}}</span>
          </div>
          {{#if cart.discountAmount}}
            <div class="flex justify-between text-green-600">
              <span>Discount ({{cart.discountCode}})</span>
              <span>-{{money cart.discountAmount}}</span>
            </div>
          {{/if}}
          <div class="flex justify-between text-gray-500">
            <span>Shipping</span>
            <span>Calculated at checkout</span>
          </div>
        </div>

        <div class="border-t border-gray-200 mt-4 pt-4 flex justify-between font-bold text-gray-900">
          <span>Total</span>
          <span>{{money cart.total}}</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function getFormData() {
  return {
    email:     document.getElementById('email').value.trim(),
    firstName: document.getElementById('firstName').value.trim(),
    lastName:  document.getElementById('lastName').value.trim(),
    line1:     document.getElementById('line1').value.trim(),
    line2:     document.getElementById('line2').value.trim(),
    city:      document.getElementById('city').value.trim(),
    county:    document.getElementById('county').value.trim(),
    postcode:  document.getElementById('postcode').value.trim(),
    country:   document.getElementById('country').value,
    phone:     document.getElementById('phone').value.trim(),
  };
}

function validateForm() {
  const d = getFormData();
  if (!d.email || !d.firstName || !d.lastName || !d.line1 || !d.city || !d.postcode || !d.country) {
    document.getElementById('payment-error').textContent = 'Please fill in all required fields.';
    document.getElementById('payment-error').classList.remove('hidden');
    return false;
  }
  document.getElementById('payment-error').classList.add('hidden');
  return true;
}

function submitStripe() {
  if (!validateForm()) return;
  const d = getFormData();
  Object.keys(d).forEach(k => {
    const el = document.getElementById('stripe-' + k);
    if (el) el.value = d[k];
  });
  document.getElementById('stripe-form').submit();
}

{{#if paypalEnabled}}
// PayPal
function initPayPal() {
  paypal.Buttons({
    createOrder: async () => {
      if (!validateForm()) throw new Error('Validation failed');
      const d = getFormData();
      const res = await fetch('/checkout/paypal/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(d),
      });
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      return data.id;
    },
    onApprove: async (data) => {
      const res = await fetch('/checkout/paypal/capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paypalOrderId: data.orderID }),
      });
      const result = await res.json();
      if (result.error) {
        document.getElementById('payment-error').textContent = result.error;
        document.getElementById('payment-error').classList.remove('hidden');
        return;
      }
      window.location.href = '/checkout/success/' + result.orderId;
    },
    onError: (err) => {
      document.getElementById('payment-error').textContent = 'PayPal error — please try again or pay by card.';
      document.getElementById('payment-error').classList.remove('hidden');
      console.error(err);
    },
  }).render('#paypal-button-container');
}

// Load PayPal SDK then init
(function() {
  const s = document.createElement('script');
  s.src = 'https://www.paypal.com/sdk/js?client-id={{paypalClientId}}&currency={{store.currency}}&intent=capture{{#if (eq paypalMode "sandbox")}}&buyer-country=GB{{/if}}';
  s.onload = initPayPal;
  document.head.appendChild(s);
})();
{{/if}}
</script>

{{> footer}}
