{{> header}}

  <!-- Hero -->
  {{#if showHero}}

  {{#if (or (eq theme.config.layout.heroPosition 'left') (eq theme.config.layout.heroPosition 'right'))}}
  {{!-- Split layout: image on one side, text on the other --}}
  <section class="overflow-hidden flex flex-col md:flex-row" style="min-height:480px">
    {{!-- Image column (left position puts it first) --}}
    {{#if (eq theme.config.layout.heroPosition 'left')}}
    <div class="relative flex-1 min-h-64 md:min-h-0">
      {{#if theme.config.layout.heroImage}}
      <img src="{{theme.config.layout.heroImage}}" alt="" class="absolute inset-0 w-full h-full object-cover">
      {{else}}
      <div class="absolute inset-0" style="background:var(--color-accent)"></div>
      {{/if}}
    </div>
    {{/if}}
    {{!-- Text column --}}
    <div class="flex-1 flex flex-col justify-center px-12 py-16 text-white" style="background:var(--color-primary)">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] mb-4" style="color:#f9a8d4">New Collection</p>
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-6">{{heroHeading}}</h1>
      <p class="text-lg mb-10 opacity-75">{{heroSubheading}}</p>
      <a href="/collections/all"
         class="self-start inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold rounded-full"
         style="background:var(--color-accent);color:white">
        Shop Now
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    {{!-- Image column (right position puts it second) --}}
    {{#if (eq theme.config.layout.heroPosition 'right')}}
    <div class="relative flex-1 min-h-64 md:min-h-0">
      {{#if theme.config.layout.heroImage}}
      <img src="{{theme.config.layout.heroImage}}" alt="" class="absolute inset-0 w-full h-full object-cover">
      {{else}}
      <div class="absolute inset-0" style="background:var(--color-accent)"></div>
      {{/if}}
    </div>
    {{/if}}
  </section>

  {{else}}
  {{!-- Full-bleed layout: image behind text (background = text left, center = text centered) --}}
  <section class="relative text-white overflow-hidden" style="background:var(--color-primary);min-height:520px">
    {{#if theme.config.layout.heroImage}}
    <img src="{{theme.config.layout.heroImage}}" alt="" class="absolute inset-0 w-full h-full object-cover opacity-30">
    {{/if}}
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 flex flex-col justify-center
                {{#if (eq theme.config.layout.heroPosition 'center')}}items-center text-center{{else}}items-start{{/if}}"
         style="min-height:520px">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] mb-4" style="color:#f9a8d4">New Collection</p>
      <h1 class="text-5xl sm:text-6xl font-bold leading-tight mb-6 max-w-2xl">{{heroHeading}}</h1>
      <p class="text-lg mb-10 max-w-md opacity-75">{{heroSubheading}}</p>
      <a href="/collections/all"
         class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold rounded-full"
         style="background:var(--color-accent);color:white">
        Shop Now
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
  {{/if}}

  {{/if}}

  <!-- Featured Products -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-baseline justify-between mb-10">
      <h2 class="text-2xl font-bold text-gray-900">Featured Products</h2>
      <a href="/collections/all" class="text-sm font-medium transition-colors" style="color:var(--color-accent)">
        View all →
      </a>
    </div>

    <div class="grid gap-8"
         style="grid-template-columns: repeat({{theme.config.layout.productsPerRow}}, minmax(0, 1fr))">
      {{#each featuredProducts}}
        {{> product-card}}
      {{/each}}
    </div>
  </section>

  <!-- Value props -->
  <section class="border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="space-y-2">
          <div class="w-10 h-10 mx-auto rounded-full flex items-center justify-center" style="background:#f3f4f6">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 text-sm">Free Shipping</h3>
          <p class="text-xs text-gray-500">On all orders over $50</p>
        </div>
        <div class="space-y-2">
          <div class="w-10 h-10 mx-auto rounded-full flex items-center justify-center" style="background:#f3f4f6">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 text-sm">30-Day Returns</h3>
          <p class="text-xs text-gray-500">Hassle-free returns</p>
        </div>
        <div class="space-y-2">
          <div class="w-10 h-10 mx-auto rounded-full flex items-center justify-center" style="background:#f3f4f6">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 text-sm">Secure Checkout</h3>
          <p class="text-xs text-gray-500">SSL encrypted payments</p>
        </div>
      </div>
    </div>
  </section>

{{> footer}}
