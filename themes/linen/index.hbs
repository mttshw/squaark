{{> header}}

  <!-- Hero -->
  {{#if showHero}}

  {{#if (or (eq theme.config.layout.heroPosition 'left') (eq theme.config.layout.heroPosition 'right'))}}
  {{!-- Split: image on one side, text on the other --}}
  <section class="hero hero--split" style="background:var(--color-hero, var(--color-primary))">
    <div class="hero__inner">

      {{#if (eq theme.config.layout.heroPosition 'left')}}
      <div class="hero__image-pane">
        {{#if theme.config.layout.heroImage}}
        <div style="position:absolute;inset:0;padding:{{theme.config.layout.heroImagePadding}};overflow:hidden;">
          <img src="{{theme.config.layout.heroImage}}" alt=""
               style="width:100%;height:100%;object-fit:{{theme.config.layout.heroImageFit}};">
        </div>
        {{else}}
        <div class="hero__image-overlay"></div>
        {{/if}}
      </div>
      {{/if}}

      <div class="hero__content{{#if (eq theme.config.layout.heroAlign 'center')}} hero__content--center{{/if}}">
        {{#if heroEyebrow}}<p class="hero__eyebrow">{{heroEyebrow}}</p>{{/if}}
        <h1 class="hero__title">{{heroHeading}}</h1>
        {{#if heroSubheading}}<p class="hero__subtitle">{{heroSubheading}}</p>{{/if}}
        <a href="/collections/all" class="hero__cta">
          Shop Now
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      {{#if (eq theme.config.layout.heroPosition 'right')}}
      <div class="hero__image-pane">
        {{#if theme.config.layout.heroImage}}
        <div style="position:absolute;inset:0;padding:{{theme.config.layout.heroImagePadding}};overflow:hidden;">
          <img src="{{theme.config.layout.heroImage}}" alt=""
               style="width:100%;height:100%;object-fit:{{theme.config.layout.heroImageFit}};">
        </div>
        {{else}}
        <div class="hero__image-overlay"></div>
        {{/if}}
      </div>
      {{/if}}

    </div>
  </section>

  {{else if (eq theme.config.layout.heroPosition 'center')}}
  {{!-- Center: text above (on hero background), image below --}}
  <section class="hero hero--stack">
    <div class="hero__stack-text{{#if (eq theme.config.layout.heroAlign 'center')}} hero__stack-text--center{{/if}}"
         style="background:var(--color-hero, var(--color-primary))">
      {{#if heroEyebrow}}<p class="hero__eyebrow">{{heroEyebrow}}</p>{{/if}}
      <h1 class="hero__title">{{heroHeading}}</h1>
      {{#if heroSubheading}}<p class="hero__subtitle">{{heroSubheading}}</p>{{/if}}
      <a href="/collections/all" class="hero__cta">
        Shop Now
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    {{#if theme.config.layout.heroImage}}
    <div class="hero__stack-image">
      <img src="{{theme.config.layout.heroImage}}" alt=""
           style="object-fit:{{theme.config.layout.heroImageFit}};padding:{{theme.config.layout.heroImagePadding}};">
    </div>
    {{/if}}
  </section>

  {{else}}
  {{!-- Background: full-bleed image behind text --}}
  <section class="hero hero--bg" style="background:var(--color-hero, var(--color-primary))">
    {{#if theme.config.layout.heroImage}}
    <div style="position:absolute;inset:0;padding:{{theme.config.layout.heroImagePadding}};overflow:hidden;opacity:0.3;">
      <img src="{{theme.config.layout.heroImage}}" alt=""
           style="width:100%;height:100%;object-fit:{{theme.config.layout.heroImageFit}};">
    </div>
    {{/if}}
    <div class="hero__content{{#if (eq theme.config.layout.heroAlign 'center')}} hero__content--center{{/if}}">
      {{#if heroEyebrow}}<p class="hero__eyebrow">{{heroEyebrow}}</p>{{/if}}
      <h1 class="hero__title">{{heroHeading}}</h1>
      {{#if heroSubheading}}<p class="hero__subtitle">{{heroSubheading}}</p>{{/if}}
      <a href="/collections/all" class="hero__cta">
        Shop Now
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
  {{/if}}

  {{/if}}

  <!-- Featured sections -->
  {{#each featuredSections}}
  {{#if this.products.length}}
  <section class="featured-section">
    <div class="container">
      <div class="featured-section__head">
        <h2 class="featured-section__title">{{this.title}}</h2>
        <a href="{{#if this.collectionSlug}}/collections/{{this.collectionSlug}}{{else}}/collections/all{{/if}}"
           class="featured-section__link">
          View all →
        </a>
      </div>

      <div class="product-grid"
           style="grid-template-columns: repeat({{../theme.config.layout.productsPerRow}}, minmax(0, 1fr))">
        {{#each this.products}}
          {{> product-card}}
        {{/each}}
      </div>
    </div>
  </section>
  {{/if}}
  {{/each}}

  <!-- Value props -->
  <section class="value-props">
    <div class="container">
      <div class="value-props__grid">
        <div>
          <div class="value-prop__icon">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="value-prop__title">Free Shipping</h3>
          <p class="value-prop__body">On all orders over $50</p>
        </div>
        <div>
          <div class="value-prop__icon">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="value-prop__title">30-Day Returns</h3>
          <p class="value-prop__body">Hassle-free returns</p>
        </div>
        <div>
          <div class="value-prop__icon">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h3 class="value-prop__title">Secure Checkout</h3>
          <p class="value-prop__body">SSL encrypted payments</p>
        </div>
      </div>
    </div>
  </section>

{{> footer}}
