{{> header}}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Search</h1>

    <!-- Search form -->
    <form action="/search" method="GET" class="mb-12">
      <div class="flex gap-3 max-w-lg">
        <input type="text" name="q" value="{{query}}" placeholder="Search products…"
               autofocus
               class="flex-1 border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-gray-300">
        <button type="submit"
                class="px-6 py-3 text-sm font-semibold text-white rounded-lg transition-all hover:opacity-90"
                style="background:var(--color-primary)">
          Search
        </button>
      </div>
    </form>

    {{#if query}}
      {{#if products.length}}
        <p class="text-sm text-gray-500 mb-8">{{products.length}} results for "<strong class="text-gray-900">{{query}}</strong>"</p>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {{#each products}}
            {{> product-card}}
          {{/each}}
        </div>
      {{else}}
        <div class="text-center py-20">
          <p class="text-gray-500 mb-2">No products found for "<strong>{{query}}</strong>".</p>
          <p class="text-sm text-gray-400">Try different keywords or browse all products.</p>
          <a href="/collections/all" class="inline-block mt-6 text-sm font-medium" style="color:var(--color-accent)">
            Browse all products →
          </a>
        </div>
      {{/if}}
    {{/if}}
  </div>

{{> footer}}
