{{> header}}

<div class="container cart-page">
  <h1 class="cart-page__title">Your {{store.cartLabel}}</h1>

  {{#if cart.empty}}
    <div style="text-align:center;padding:6rem 0;">
      <p style="color:#9ca3af;font-size:1.125rem;margin-bottom:1rem;">Your {{store.cartLabel}} is empty.</p>
      <a href="/collections/all" class="btn btn-primary" style="display:inline-block;">Continue Shopping</a>
    </div>
  {{else}}
    <div class="cart-layout">

      <!-- Items -->
      <div>
        {{> cart-contents}}
      </div>

      <!-- Summary -->
      <div>
        <div class="cart-summary">
          <h2 class="cart-summary__title">Order summary</h2>

          <div class="summary-rows">
            <div class="summary-row">
              <span>Subtotal ({{pluralize cart.itemCount "item" "items"}})</span>
              <span>{{money cart.subtotal}}</span>
            </div>
            {{#if cart.discountAmount}}
              <div class="summary-row summary-row--discount">
                <span>Discount ({{cart.discountCode}})</span>
                <span>-{{money cart.discountAmount}}</span>
              </div>
            {{/if}}
            <div class="summary-row summary-row--muted">
              <span>Shipping</span>
              <span>Calculated at checkout</span>
            </div>
          </div>

          <div class="summary-total">
            <span>Total</span>
            <span>{{money cart.total}}</span>
          </div>

          <div class="discount-row">
            <input type="text" name="discount" placeholder="Discount code" class="store-input" style="flex:1;">
            <button type="submit" class="btn btn-secondary btn-sm">Apply</button>
          </div>

          <a href="{{cart.checkoutUrl}}"
             class="btn btn-block"
             style="margin-top:1rem;background:var(--color-accent);color:#fff;display:flex;justify-content:center;">
            Proceed to Checkout
          </a>

          <a href="/collections/all" style="display:block;text-align:center;font-size:0.75rem;color:#9ca3af;margin-top:0.75rem;">
            ← Continue Shopping
          </a>
        </div>
      </div>
    </div>
  {{/if}}
</div>

{{> footer}}
